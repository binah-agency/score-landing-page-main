---
// Assets Promo - Tarjetas de nivel
import cardZafiro from '../../assest/promo/card-zafiro.png?url';
import cardEsmeralda from '../../assest/promo/card-esmeralda.png?url';
import cardSilver from '../../assest/promo/card-silver.png?url';
import cardGold from '../../assest/promo/card-gold.png?url';
import cardElite from '../../assest/promo/card-elite.png?url';

const cards = [
  { src: cardZafiro, alt: 'ID Zafiro' },
  { src: cardEsmeralda, alt: 'ID Esmeralda' },
  { src: cardSilver, alt: 'ID Silver' },
  { src: cardGold, alt: 'ID Gold' },
  { src: cardElite, alt: 'ID Elite' },
];
---

<section class="relative w-full overflow-hidden py-10" id="promo">
  <!-- Gradientes laterales -->
  <div class="pointer-events-none absolute left-0 top-0 z-40 h-full w-[400px]" style="background: linear-gradient(90deg, white 37%, rgba(255, 255, 255, 0) 94%);"></div>
  <div class="pointer-events-none absolute right-0 top-0 z-40 h-full w-[400px]" style="background: linear-gradient(270deg, white 37%, rgba(255, 255, 255, 0) 94%);"></div>

  <!-- Container centrado -->
  <div class="mx-auto flex w-full max-w-[1920px] flex-col items-center gap-6 px-4">
    
    <!-- Título -->
    <div class="w-full max-w-[1306px] px-[52px] text-center">
      <p class="font-montserrat text-[32px] font-medium capitalize leading-[64px] text-[var(--color-verdevitalidad)]">
        TU NIVEL DE CONFIANZA
      </p>
      <p class="font-montserrat text-[52px] font-bold leading-[64px]">
        <span class="text-[var(--color-black)]">Evoluciona tu </span>
        <span class="text-[var(--color-azulhorizonte)]">ID DE CONFIANZA</span>
      </p>
    </div>

    <!-- Área del carrusel -->
    <div class="relative flex h-[450px] w-full items-center justify-center">
      <!-- Contenedor de tarjetas -->
      <div id="promo-carousel" class="relative flex h-full w-full items-center justify-center">
        {cards.map((card, index) => (
          <div 
            class="promo-card absolute cursor-pointer transition-all duration-700 ease-out"
            data-index={index}
          >
            <img 
              src={card.src} 
              alt={card.alt}
              class="h-full w-full rounded-[20px] object-contain shadow-2xl"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Indicadores -->
    <div class="flex items-center justify-center gap-[7px]">
      {cards.map((_, index) => (
        <button 
          class="promo-dot h-4 w-[62px] rounded-[24px] bg-[var(--color-azulhorizonte)] transition-colors duration-300" 
          data-index={index}
          aria-label={`Slide ${index + 1}`}
        />
      ))}
    </div>

    <!-- Párrafo descriptivo -->
    <div class="w-full max-w-[1043px] px-5">
      <p class="text-center font-montserrat text-[24px] font-medium leading-7 text-[var(--color-black)]">
        Desde tu ID Zafiro hasta convertirte en un miembro Élite. Cada nivel<br/>
        desbloquea nuevas ofertas financieras verificadas por el sistema DSS de Crediscore
      </p>
    </div>
  </div>
</section>

<style>
  .promo-card {
    transform-origin: center center;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.promo-card') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('.promo-dot');
    
    if (!cards.length || !dots.length) return;

    const TOTAL_CARDS = 5;
    let currentIndex = 2; // Silver en el centro
    let autoplayTimer: ReturnType<typeof setInterval>;

    // Tamaños según Figma
    const LARGE_WIDTH = 621;
    const LARGE_HEIGHT = 393;
    const SMALL_WIDTH = 403;
    const SMALL_HEIGHT = 254;

    // Configuración de posiciones
    // Centro = tarjeta grande, laterales = pequeñas
    const positions = {
      farLeft: { x: -700, width: SMALL_WIDTH, height: SMALL_HEIGHT, opacity: 0, zIndex: 1, top: 70 },
      left: { x: -420, width: SMALL_WIDTH, height: SMALL_HEIGHT, opacity: 0.9, zIndex: 2, top: 70 },
      center: { x: 0, width: LARGE_WIDTH, height: LARGE_HEIGHT, opacity: 1, zIndex: 3, top: 0 },
      right: { x: 420, width: SMALL_WIDTH, height: SMALL_HEIGHT, opacity: 0.9, zIndex: 2, top: 70 },
      farRight: { x: 700, width: SMALL_WIDTH, height: SMALL_HEIGHT, opacity: 0, zIndex: 1, top: 70 },
    };

    function getPosition(cardIndex: number, activeIndex: number): keyof typeof positions {
      const diff = (cardIndex - activeIndex + TOTAL_CARDS) % TOTAL_CARDS;
      
      if (diff === 0) return 'center';
      if (diff === 1) return 'right';
      if (diff === TOTAL_CARDS - 1) return 'left';
      if (diff === 2) return 'farRight';
      return 'farLeft';
    }

    function updateCarousel() {
      cards.forEach((card, index) => {
        const posKey = getPosition(index, currentIndex);
        const pos = positions[posKey];
        
        // Aplicar estilos
        card.style.transform = `translateX(${pos.x}px) translateY(${pos.top}px)`;
        card.style.width = `${pos.width}px`;
        card.style.height = `${pos.height}px`;
        card.style.opacity = String(pos.opacity);
        card.style.zIndex = String(pos.zIndex);
      });

      // Actualizar dots
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.remove('bg-[var(--color-azulhorizonte)]');
          dot.classList.add('bg-[var(--color-verdevitalidad)]');
        } else {
          dot.classList.remove('bg-[var(--color-verdevitalidad)]');
          dot.classList.add('bg-[var(--color-azulhorizonte)]');
        }
      });
    }

    function goToSlide(index: number) {
      currentIndex = index;
      updateCarousel();
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % TOTAL_CARDS;
      updateCarousel();
    }

    function startAutoplay() {
      autoplayTimer = setInterval(nextSlide, 4000);
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      startAutoplay();
    }

    // Click en dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        goToSlide(index);
        resetAutoplay();
      });
    });

    // Click en tarjetas
    cards.forEach((card, index) => {
      card.addEventListener('click', () => {
        goToSlide(index);
        resetAutoplay();
      });
    });

    // Inicializar con Silver en el centro
    updateCarousel();
    startAutoplay();
  });
</script>

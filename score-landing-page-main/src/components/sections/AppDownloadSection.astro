---
// AppDownloadSection - Cta-AppDownload
// Fondo azul degradado, badges de stores, iconos sociales, mockup celular
import phoneMockup from '../../assest/tlfn.png?url';
---

<section class="w-full bg-[var(--color-azulhorizonte)]" id="app-download">
  <div class="mx-auto flex w-full max-w-[1920px] items-center justify-center gap-[24px] px-[60px] py-[50px]">
    
    <!-- Contenido izquierdo -->
    <div class="flex w-[820px] flex-col items-start gap-[43px]">
      
      <!-- Título principal: 64px extrabold -->
      <h2 class="font-montserrat text-[64px] font-extrabold leading-[80px] text-white">
        ¡Construye tu Confianza<br/>AHORA!
      </h2>
      
      <!-- Subtítulo: 36px extrabold -->
      <p class="font-montserrat text-[36px] font-extrabold leading-normal text-white">
        No te quedes atrás y empieza<br/>a certificar el valor de tu cumplimiento
      </p>
      
      <!-- Badges y redes sociales -->
      <div class="flex items-start gap-[65px]">
        
        <!-- Badges de stores -->
        <div class="flex flex-col items-start gap-[30px]">
          <!-- Google Play -->
          <a href="#" class="transition-opacity hover:opacity-90">
            <img src="/images/google-play-badge.png" alt="Disponible en Google Play" class="h-[100px] w-[300px] object-cover" />
          </a>
          
          <!-- App Store -->
          <a href="#" class="transition-opacity hover:opacity-90">
            <img src="/images/app-store-badge.svg" alt="Descargar en App Store" class="h-[100px] w-[300px] object-cover" />
          </a>
        </div>
        
        <!-- Iconos de redes sociales -->
        <div class="flex w-[60px] flex-col gap-[10px]">
          <a href="#" class="flex h-[60px] w-[60px] items-center justify-center rounded-[14px] bg-white transition-transform hover:scale-105">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="#3467b0">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <a href="#" class="flex h-[60px] w-[60px] items-center justify-center rounded-[14px] bg-white transition-transform hover:scale-105">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="#3467b0">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="flex h-[60px] w-[60px] items-center justify-center rounded-[14px] bg-white transition-transform hover:scale-105">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="#3467b0">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <a href="#" class="flex h-[60px] w-[60px] items-center justify-center rounded-[14px] bg-white transition-transform hover:scale-105">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="#3467b0">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Mockup celular -->
    <div class="flex w-[292px] items-center justify-center">
      <img 
        src={phoneMockup} 
        alt="CrediScore App" 
        class="h-auto w-full max-w-[292px]"
      />
    </div>
  </div>
</section>

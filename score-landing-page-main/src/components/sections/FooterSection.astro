          </a>
          <a href="#" class="flex h-[40px] w-[40px] items-center justify-center transition-opacity hover:opacity-80">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Columna 2: Enlaces Rápidos -->
      <div class="flex w-[186px] flex-col items-start gap-[20px] justify-self-center">
        <h3 class="font-montserrat text-[20px] font-extrabold leading-[80px] text-white">
          Enlaces Rápidos
        </h3>
        <nav class="flex flex-col font-montserrat text-[16px] font-medium leading-[30px] text-white">
          <a href="#" class="transition-colors hover:text-[var(--color-verdevitalidad)]">Quienes somos</a>
          <a href="#" class="transition-colors hover:text-[var(--color-verdevitalidad)]">Servicios</a>
          <a href="#" class="transition-colors hover:text-[var(--color-verdevitalidad)]">Credi Persona</a>
          <a href="#" class="transition-colors hover:text-[var(--color-verdevitalidad)]">Credi Empresa</a>
          <a href="/terminos-y-condiciones" class="whitespace-nowrap transition-colors hover:text-[var(--color-verdevitalidad)]">Terminos y Condiciones</a>
          <a href="/privacidad" class="transition-colors hover:text-[var(--color-verdevitalidad)]">Politica de Privacidad</a>
        </nav>
      </div>
    </div>
    
    <!-- CTA Central con bordes -->
    <div class="flex w-full items-center justify-center gap-[20px] border-b border-t border-[#ccc] py-[40px]">
      <p class="font-montserrat text-[36px] font-extrabold leading-[80px] text-white">
        Certifica tu Reputación Comercial
      </p>
      <a 
        href="#" 
        class="flex h-[55px] w-[202px] items-center justify-center rounded-[32px] bg-[var(--color-azulhorizonte)] p-[12px] transition-opacity hover:opacity-90"
      >
        <span class="font-montserrat text-[20px] font-semibold text-white">
          Descargar App
        </span>
      </a>
    </div>
  </div>
  
  <!-- Copyright -->
  <div class="flex w-full flex-col items-center py-[40px]">
    <p class="text-center font-montserrat text-[16px] font-medium leading-[28px] text-white">
      2026 CREDISCORE VENEZUELA. TODOS LOS DERECHOS RESERVADOS
    </p>
  </div>
</footer>

---
import arrowUp from '../../assest/back-to-top-arrow.svg?url';

interface Props {
  targetId?: string;
  class?: string;
}

const { targetId = 'top', class: className = '' } = Astro.props;
---

<a
  href={`#${targetId}`}
  aria-label="Ir arriba"
  class:list={[
    'fixed bottom-6 right-6 z-50 hidden h-[70px] w-[169px] items-center justify-center rounded-[48px] bg-[rgba(245,124,0,0.6)] px-3 text-white shadow-lg backdrop-blur-sm transition-opacity hover:opacity-90 lg:flex',
    className,
  ]}
>
  <span class="mr-3 text-[20px] font-semibold">Ir arriba</span>
  <img src={arrowUp} alt="Subir" class="h-10 w-10" />
</a>

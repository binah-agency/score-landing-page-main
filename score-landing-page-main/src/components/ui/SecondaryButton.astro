---
interface Props {
  label: string;
  href?: string;
  class?: string;
}

const { label, href = '#', class: className = '' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'inline-flex h-14 items-center justify-center whitespace-nowrap rounded-lg border-2 border-[var(--color-azulhorizonte,#3467b0)] px-6 text-[20px] font-semibold text-[var(--color-azulhorizonte,#3467b0)] transition-colors hover:bg-[var(--color-azulhorizonte,#3467b0)] hover:text-white',
    className,
  ]}
>
  {label}
</a>

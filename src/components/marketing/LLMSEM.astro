---

<!-- LLM SEM Schema - JSON-LD Structured Data for Language Models -->
<script type="application/ld+json">
{
  "@context": [
    "https://schema.org",
    {
      "crediscore": "https://crediscore.ve/schema/",
      "intent": "crediscore:intent",
      "semanticKeyword": "crediscore:semanticKeyword"
    }
  ],
  "@type": ["Organization", "WebApplication"],
  "name": "${entity}",
  "description": "${entityDescription}",
  "category": "${primaryCategory}",
  "additionalType": [
    {secondaryCategories.map(cat => `"${cat}"`).join(',')}
  ],
  "keywords": [
    {keywords.map(kw => `"${kw}"`).join(',')}
  ],
  "semanticKeywords": [
    {semanticKeywords.map(kw => `"${kw}"`).join(',')}
  ],
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {questions.map(q => `{
        "@type": "Question",
        "name": "${q.question}",
        "text": "${q.question}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "${q.answer}",
          "author": "${entity}"
        },
        "intent": "${q.intent}",
        "context": "${q.context}",
        "entities": [
          {q.entities.map(ent => `"${ent}"`).join(',')}
        ]
      }`).join(',')}
    ]
  },
  "offers": {
    "@type": "AggregateOffer",
    "itemOffered": {
      "@type": "Service",
      "name": "${primaryCategory}",
      "description": "${entityDescription}",
      "provider": "${entity}"
    }
  },
  "process": [
    {processes.map(p => `{
      "@type": "HowTo",
      "name": "${p.name}",
      "description": "Proceso para ${p.name.toLowerCase()}",
      "steps": [
        {p.steps.map((step, index) => `{
          "@type": "HowToStep",
          "position": ${index + 1},
          "text": "${step}"
        }`).join(',')}
      ],
      "totalTime": "${p.duration}",
      "requirements": [
        {p.requirements.map(req => `"${req}"`).join(',')}
      ],
      "expectedResult": [
        {p.outcomes.map(outcome => `"${outcome}"`).join(',')}
      ]
    }`).join(',')}
  ],
  "definedTerms": [
    {definitions.map(d => `{
      "@type": "DefinedTerm",
      "name": "${d.term}",
      "description": "${d.definition}",
      "inDefinedTermSet": "Glosario CrediScore",
      "examples": [
        {d.examples.map(ex => `"${ex}"`).join(',')}
      ],
      "relatedTerms": [
        {d.relatedTerms.map(term => `"${term}"`).join(',')}
      ]
    }`).join(',')}
  ],
  "comparisons": [
    {comparisons.map(c => `{
      "@type": "Compare",
      "itemReviewed": "${entity}",
      "itemCompared": "${c.vs}",
      "comparisonResult": "${c.winner}",
      "comparisonCriteria": {
        "@type": "ItemList",
        "itemListElement": [
          "Adaptación local",
          "Tecnología",
          "Accesibilidad",
          "Transparencia"
        ]
      },
      "differences": [
        {c.differences.map(diff => `"${diff}"`).join(',')}
      ],
      "similarities": [
        {c.similarities.map(sim => `"${sim}"`).join(',')}
      ],
      "reasoning": "${c.reasoning}"
    }`).join(',')}
  ],
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Mercado",
      "value": "Venezuela y LATAM"
    },
    {
      "@type": "PropertyValue",
      "name": "Tecnología",
      "value": "Sistema de Apoyo a Decisiones (DSS)"
    },
    {
      "@type": "PropertyValue",
      "name": "Metodología",
      "value": "Análisis de comportamiento comercial"
    }
  ]
}
</script>

<!-- Extended LLM Content as WebPage Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "${entity} - ${primaryCategory}",
  "description": "${entityDescription}",
  "url": "https://crediscore.ve",
  "about": [
    {keywords.map(kw => `"${kw}"`).join(',')}
  ],
  "mainEntity": {
    "@type": "Organization",
    "name": "${entity}",
    "description": "${entityDescription}",
    "knowsAbout": [
      {keywords.map(kw => `"${kw}"`).join(',')}
    ]
  },
  "mentions": [
    {services.map(service => `"${service}"`).join(',')}
  ],
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://crediscore.ve"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "${primaryCategory}",
        "item": "https://crediscore.ve/services"
      }
    ]
  }
}
</script>

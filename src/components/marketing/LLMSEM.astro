---
// src/components/LLMSEM.astro
import llmSemConfig from '../../data/marketing/llm-sem-config.json';

interface Props {
  entity?: EntityConfig;
  content?: SEMContent;
  schema?: SchemaConfig;
  output?: OutputConfig;
}

// ───────── Declarative Type Definitions ─────────
type EntityConfig = {
  name: string;
  description: string;
  primaryCategory: string;
  secondaryCategories?: string[];
  url?: string;
  logo?: string;
  sameAs?: string[];  // Social/profile URLs
};

type SEMContent = {
  keywords?: {
    primary?: string[];
    semantic?: string[];
    longTail?: string[];
  };
  questions?: FAQItem[];
  comparisons?: ComparisonItem[];
  processes?: ProcessItem[];
  definitions?: DefinitionItem[];
};

type FAQItem = {
  question: string;
  answer: string;
  intent: 'informational' | 'comparative' | 'procedural' | 'beneficial' | 'concern' | 'commercial';
  context: string;
  entities: string[];
  relatedQuestions?: string[];
};

type ComparisonItem = {
  vs: string;
  differences: string[];
  similarities: string[];
  winner: string;
  reasoning: string;
  criteria?: string[];
};

type ProcessItem = {
  name: string;
  steps: string[];
  duration: string;  // ISO 8601 duration or human-readable
  requirements: string[];
  outcomes: string[];
  difficulty?: 'easy' | 'medium' | 'hard';
};

type DefinitionItem = {
  term: string;
  definition: string;
  examples: string[];
  relatedTerms: string[];
  context: string;
  url?: string;  // Link to authoritative source
};

type SchemaConfig = {
  customContext?: Record<string, string>;  // Extend schema.org
  includeOrganization?: boolean;
  includeWebApplication?: boolean;
  includeWebPage?: boolean;
  includeFAQ?: boolean;
  includeHowTo?: boolean;
  includeDefinedTerm?: boolean;
  includeCompare?: boolean;  // Non-standard, for LLMs
  aggregateOffer?: {
    price?: string;
    priceCurrency?: string;
    availability?: string;
  };
};

type OutputConfig = {
  emitJSONLD?: boolean;
  emitMicrodata?: boolean;  // Future: HTML microdata fallback
  prettyPrint?: boolean;
  minify?: boolean;
};

type SchemaObject = {
  "@context": any;
  "@type": string | string[];
  name: string;
  description: string;
  category: string;
  additionalType?: string[];
  url?: string;
  logo?: string;
  sameAs?: string[];
  offers?: {
    "@type": string;
    price?: string;
    priceCurrency?: string;
    availability?: string;
    itemOffered: {
      "@type": string;
      name: string;
      description: string;
      provider: string;
    };
  };
  mainEntity?: any;
  process?: any[];
  definedTerms?: any[];
  comparisons?: any[];
  additionalProperty?: any[];
};

// ───────── Default Configuration Loaded from JSON (Declarative Source of Truth) ─────────
const defaultEntity: EntityConfig = llmSemConfig.defaultEntity as EntityConfig;

const defaultContent: SEMContent = llmSemConfig.defaultContent as SEMContent;

const defaultSchema: SchemaConfig = llmSemConfig.defaultSchema as SchemaConfig;

const defaultOutput: OutputConfig = llmSemConfig.defaultOutput as OutputConfig;

// ───────── Merge Props with Defaults (Immutable, Deep Merge) ─────────
const {
  entity = {},
  content = {},
  schema = {},
  output = {}
} = Astro.props;

const cfg = {
  entity: { ...defaultEntity, ...entity },
  content: {
    ...defaultContent,
    ...content,
    keywords: { ...defaultContent.keywords, ...content.keywords }
  },
  schema: { ...defaultSchema, ...schema },
  output: { ...defaultOutput, ...output }
};

// ───────── Pure JSON-LD Generators (Declarative, Testable) ─────────
const escapeJSON = (str: string) => 
  str.replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '').replace(/\t/g, '  ');

const generateOrganizationSchema = (e: EntityConfig, s: SchemaConfig): SchemaObject => ({
  "@context": [
    "https://schema.org",
    ...(s.customContext ? [s.customContext] : [])
  ],
  "@type": ["Organization", ...(s.includeWebApplication ? ["WebApplication"] : [])],
  "name": e.name,
  "description": e.description,
  "category": e.primaryCategory,
  ...(e.secondaryCategories?.length && { "additionalType": e.secondaryCategories }),
  "url": e.url,
  ...(e.logo && { "logo": e.logo }),
  ...(e.sameAs?.length && { "sameAs": e.sameAs }),
  ...(s.aggregateOffer && {
    "offers": {
      "@type": "AggregateOffer",
      "price": s.aggregateOffer.price,
      "priceCurrency": s.aggregateOffer.priceCurrency,
      "availability": s.aggregateOffer.availability,
      "itemOffered": {
        "@type": "Service",
        "name": e.primaryCategory,
        "description": e.description,
        "provider": e.name
      }
    }
  })
});

const generateFAQSchema = (items: FAQItem[]) => ({
  "@type": "FAQPage",
  "mainEntity": items.map(q => ({
    "@type": "Question",
    "name": q.question,
    "text": q.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": q.answer,
      "author": cfg.entity.name
    },
    ...(q.intent && { "intent": q.intent }),
    ...(q.context && { "context": q.context }),
    ...(q.entities?.length && { "entities": q.entities }),
    ...(q.relatedQuestions?.length && { "relatedQuestions": q.relatedQuestions })
  }))
});

const generateHowToSchema = (items: ProcessItem[]) => items.map(p => ({
  "@type": "HowTo",
  "name": p.name,
  "description": `Proceso para ${p.name.toLowerCase()}`,
  "step": p.steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "text": step
  })),
  "totalTime": p.duration,
  ...(p.requirements?.length && { "requirements": p.requirements }),
  ...(p.outcomes?.length && { "expectedResult": p.outcomes }),
  ...(p.difficulty && { "difficulty": p.difficulty })
}));

const generateDefinitionsSchema = (items: DefinitionItem[]) => items.map(d => ({
  "@type": "DefinedTerm",
  "name": d.term,
  "description": d.definition,
  "inDefinedTermSet": `Glosario ${cfg.entity.name}`,
  ...(d.examples?.length && { "examples": d.examples }),
  ...(d.relatedTerms?.length && { "relatedTerms": d.relatedTerms }),
  ...(d.context && { "termContext": d.context }),
  ...(d.url && { "url": d.url })
}));

const generateCompareSchema = (items: ComparisonItem[], entityName: string) => items.map(c => ({
  "@type": "Compare",
  "itemReviewed": entityName,
  "itemCompared": c.vs,
  "comparisonResult": c.winner,
  ...(c.criteria?.length && {
    "comparisonCriteria": {
      "@type": "ItemList",
      "itemListElement": c.criteria
    }
  }),
  "differences": c.differences,
  "similarities": c.similarities,
  "reasoning": c.reasoning
}));

const generateWebPageSchema = (e: EntityConfig, c: SEMContent) => ({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${e.name} - ${e.primaryCategory}`,
  "description": e.description,
  "url": e.url,
  "about": c.keywords?.primary || [],
  "mainEntity": {
    "@type": "Organization",
    "name": e.name,
    "description": e.description,
    "knowsAbout": c.keywords?.primary
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": e.url },
      { "@type": "ListItem", "position": 2, "name": e.primaryCategory, "item": `${e.url}/services` }
    ]
  }
});

const generateKeywordSchema = (c: SEMContent) => ({
  "@type": "ItemList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Primary Keywords",
      "itemListElement": c.keywords?.primary?.map((kw, i) => ({
        "@type": "ListItem", "position": i + 1, "name": kw
      }))
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Semantic Keywords",
      "itemListElement": c.keywords?.semantic?.map((kw, i) => ({
        "@type": "ListItem", "position": i + 1, "name": kw,
        "additionalProperty": { "@type": "PropertyValue", "name": "semanticKeyword", "value": kw }
      }))
    }
  ]
});

// ───────── Compose Final Schema Object ─────────
const generateFullSchema = () => {
  const { entity: e, content: c, schema: s } = cfg;
  
  const base = generateOrganizationSchema(e, s);
  
  // Add FAQ
  if (s.includeFAQ && c.questions?.length) {
    base.mainEntity = generateFAQSchema(c.questions);
  }
  
  // Add HowTo processes
  if (s.includeHowTo && c.processes?.length) {
    base.process = generateHowToSchema(c.processes);
  }
  
  // Add Definitions
  if (s.includeDefinedTerm && c.definitions?.length) {
    base.definedTerms = generateDefinitionsSchema(c.definitions);
  }
  
  // Add Comparisons (custom type for LLMs)
  if (s.includeCompare && c.comparisons?.length) {
    base.comparisons = generateCompareSchema(c.comparisons, e.name);
  }
  
  // Add keywords list
  if (c.keywords?.primary?.length || c.keywords?.semantic?.length) {
    base.additionalProperty = [
      ...(base.additionalProperty || []),
      generateKeywordSchema(c)
    ];
  }
  
  // Add custom properties
  base.additionalProperty = [
    ...(base.additionalProperty || []),
    { "@type": "PropertyValue", "name": "Mercado", "value": "Venezuela y LATAM" },
    { "@type": "PropertyValue", "name": "Tecnología", "value": "Sistema de Apoyo a Decisiones (DSS)" },
    { "@type": "PropertyValue", "name": "Metodología", "value": "Análisis de comportamiento comercial" }
  ];
  
  return base;
};
---

<!-- LLM SEM Structured Data - Declarative JSON-LD Injection -->
{cfg.output.emitJSONLD && cfg.schema.includeOrganization && (
  <script type="application/ld+json" set:html={JSON.stringify(generateFullSchema(), null, cfg.output.prettyPrint ? 2 : 0)} />
)}

{cfg.output.emitJSONLD && cfg.schema.includeWebPage && (
  <script type="application/ld+json" set:html={JSON.stringify(generateWebPageSchema(cfg.entity, cfg.content), null, cfg.output.prettyPrint ? 2 : 0)} />
)}

<!-- Optional: Expose raw schema for programmatic access -->
{cfg.output.prettyPrint && (
  <script type="application/json" id="llm-sem-schema" set:html={JSON.stringify({ main: generateFullSchema(), webpage: generateWebPageSchema(cfg.entity, cfg.content) }, null, 2)} />
)}
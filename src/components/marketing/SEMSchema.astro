---
// src/components/SEMSchema.astro
import semSchemaConfig from '../../data/marketing/sem-schema-config.json';

interface Props {
  entity?: EntityConfig;
  schemas?: SchemaConfig;
  output?: OutputConfig;
}

// ───────── Declarative Type Definitions ─────────
type EntityConfig = {
  // Core identity
  name: string;
  description: string;
  url: string;
  
  // Branding
  logo?: string;
  image?: string;
  
  // Contact
  telephone?: string;
  email?: string;
  address?: string | PostalAddressConfig;
  
  // Business details
  foundingDate?: string;
  numberOfEmployees?: string;  // schema.org range: "1-10", "11-50", etc.
  areaServed?: string | string[];  // ISO code or array: "VE" | ["VE", "CO"]
  priceRange?: string;  // "$", "$$", "$$$"
  
  // Service specifics
  serviceType?: string;
  serviceDescription?: string;
  serviceOffers?: ServiceOffer[];
  
  // Social & discovery
  sameAs?: string[];  // Social/profile URLs
  keywords?: string[];
  
  // Local business
  geo?: GeoCoordinatesConfig;
  openingHours?: string[];  // schema.org format: "Mo-Fr 09:00-18:00"
  paymentAccepted?: string[];
  currenciesAccepted?: string;
  
  // FAQ content
  faq?: FAQItem[];
};

type PostalAddressConfig = {
  "@type"?: string;
  streetAddress?: string;
  addressLocality?: string;
  addressRegion?: string;
  postalCode?: string;
  addressCountry?: string;  // ISO code
};

type GeoCoordinatesConfig = {
  "@type"?: string;
  latitude: string;
  longitude: string;
};

type ServiceOffer = {
  name: string;
  description: string;
  url?: string;
  price?: string;
  priceCurrency?: string;
};

type FAQItem = {
  question: string;
  answer: string;
  answerHtml?: string;  // For rich HTML answers
};

type SchemaConfig = {
  // Toggle individual schema types
  includeOrganization?: boolean;
  includeWebsite?: boolean;
  includeService?: boolean;
  includeFAQ?: boolean;
  includeLocalBusiness?: boolean;
  
  // Extend/override schema properties
  organization?: Partial<OrganizationSchema>;
  website?: Partial<WebsiteSchema>;
  service?: Partial<ServiceSchema>;
  faq?: Partial<FAQSchema>;
  localBusiness?: Partial<LocalBusinessSchema>;
  
  // Custom schema additions
  additionalSchemas?: Record<string, unknown>[];
};

type OutputConfig = {
  emitJSONLD?: boolean;
  prettyPrint?: boolean;
  minify?: boolean;
  commentLabels?: boolean;  // Add HTML comments for debugging
};

// ───────── Schema Type Interfaces (for extensions) ─────────
type OrganizationSchema = {
  "@type": string;
  name: string;
  description: string;
  url: string;
  logo?: string;
  image?: string;
  telephone?: string;
  email?: string;
  address?: PostalAddressConfig;
  foundingDate?: string;
  numberOfEmployees?: string;
  areaServed?: string | string[];
  priceRange?: string;
  openingHours?: string[];
  sameAs?: string[];
  contactPoint?: ContactPointConfig;
  [key: string]: unknown;
};

type WebsiteSchema = {
  "@type": "WebSite";
  name: string;
  url: string;
  description?: string;
  potentialAction?: SearchActionConfig;
  [key: string]: unknown;
};

type ServiceSchema = {
  "@type": "Service";
  name: string;
  description: string;
  provider: { "@type": string; name: string; url: string };
  serviceType: string;
  areaServed?: string | string[];
  hasOfferCatalog?: OfferCatalogConfig;
  [key: string]: unknown;
};

type FAQSchema = {
  "@context": string;
  "@type": "FAQPage";
  mainEntity: Array<{
    "@type": "Question";
    name: string;
    acceptedAnswer: {
      "@type": "Answer";
      text: string;
      [key: string]: unknown;
    };
  }>;
};

type LocalBusinessSchema = {
  "@type": string;  // "FinancialService", "LocalBusiness", etc.
  name: string;
  description: string;
  url: string;
  telephone?: string;
  email?: string;
  address: PostalAddressConfig;
  geo?: GeoCoordinatesConfig;
  openingHours?: string[];
  priceRange?: string;
  paymentAccepted?: string[];
  currenciesAccepted?: string;
  [key: string]: unknown;
};

type ContactPointConfig = {
  "@type": "ContactPoint";
  telephone: string;
  contactType: string;
  availableLanguage?: string[];
  areaServed?: string[];
};

type SearchActionConfig = {
  "@type": "SearchAction";
  target: {
    "@type": "EntryPoint";
    urlTemplate: string;
  };
  "query-input": string;
};

type OfferCatalogConfig = {
  "@type": "OfferCatalog";
  name: string;
  itemListElement: Array<{
    "@type": "Offer";
    itemOffered: {
      "@type": "Service";
      name: string;
      description: string;
      url?: string;
    };
  }>;
};

// ───────── Default Configuration Loaded from JSON (Declarative Source of Truth) ─────────
const defaultEntity: EntityConfig = semSchemaConfig.defaultEntity as EntityConfig;

const defaultSchemas: SchemaConfig = semSchemaConfig.defaultSchemas as SchemaConfig;

const defaultOutput: OutputConfig = {
  ...semSchemaConfig.defaultOutput as OutputConfig,
  commentLabels: import.meta.env.DEV
};

// ───────── Merge Props with Defaults (Immutable) ─────────
const {
  entity = {},
  schemas = {},
  output = {}
} = Astro.props;

const cfg = {
  entity: { ...defaultEntity, ...entity },
  schemas: { ...defaultSchemas, ...schemas },
  output: { ...defaultOutput, ...output }
};

// ───────── Pure Schema Generators (Declarative, Testable) ─────────
const generateOrganizationSchema = (e: EntityConfig, overrides?: Partial<OrganizationSchema>): OrganizationSchema => ({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": e.name,
  "description": e.description,
  "url": e.url,
  ...(e.logo && { "logo": e.logo }),
  ...(e.image && { "image": e.image }),
  ...(e.telephone && { "telephone": e.telephone }),
  ...(e.email && { "email": e.email }),
  ...(e.address && {
    "address": typeof e.address === 'string' 
      ? { "@type": "PostalAddress", "addressCountry": "VE", "addressLocality": e.address }
      : { "@type": "PostalAddress", ...e.address }
  }),
  ...(e.foundingDate && { "foundingDate": e.foundingDate }),
  ...(e.numberOfEmployees && { "numberOfEmployees": e.numberOfEmployees }),
  ...(e.areaServed && { "areaServed": e.areaServed }),
  ...(e.serviceType && { "serviceType": e.serviceType }),
  ...(e.priceRange && { "priceRange": e.priceRange }),
  ...(e.openingHours?.length && { "openingHours": e.openingHours }),
  ...(e.sameAs?.length && { "sameAs": e.sameAs }),
  ...(e.telephone && {
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": e.telephone,
      "contactType": "customer service",
      "availableLanguage": ["Spanish"]
    }
  }),
  ...overrides
});

const generateWebsiteSchema = (e: EntityConfig, overrides?: Partial<WebsiteSchema>): WebsiteSchema => ({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": e.name,
  "url": e.url,
  ...(e.description && { "description": e.description }),
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${e.url}/search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  },
  ...overrides
});

const generateServiceSchema = (e: EntityConfig, overrides?: Partial<ServiceSchema>): ServiceSchema => ({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": e.serviceType || "Scoring Crediticio",
  "description": e.serviceDescription || "Evaluación de confianza técnica y reputación comercial en Venezuela",
  "provider": {
    "@type": "Organization",
    "name": e.name,
    "url": e.url
  },
  "serviceType": e.serviceType || "Financial Service",
  ...(e.areaServed && { "areaServed": e.areaServed }),
  ...(e.serviceOffers?.length && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": `Servicios de ${e.name}`,
      "itemListElement": e.serviceOffers.map(offer => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": offer.name,
          "description": offer.description,
          ...(offer.url && { "url": offer.url })
        }
      }))
    }
  }),
  ...overrides
});

const generateFAQSchema = (items: FAQItem[], overrides?: Partial<FAQSchema>): FAQSchema => ({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
      ...(faq.answerHtml && { "text": faq.answerHtml })
    }
  })),
  ...overrides
});

const generateLocalBusinessSchema = (e: EntityConfig, overrides?: Partial<LocalBusinessSchema>): LocalBusinessSchema => ({
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "name": e.name,
  "description": e.description,
  "url": e.url,
  ...(e.telephone && { "telephone": e.telephone }),
  ...(e.email && { "email": e.email }),
  "address": typeof e.address === 'string'
    ? {
        "@type": "PostalAddress",
        "addressCountry": "VE",
        "addressLocality": e.address,
        "streetAddress": "Avenida Libertador, Caracas"
      }
    : { "@type": "PostalAddress", ...e.address },
  ...(e.geo && {
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": e.geo.latitude,
      "longitude": e.geo.longitude
    }
  }),
  ...(e.openingHours?.length && { "openingHours": e.openingHours }),
  ...(e.priceRange && { "priceRange": e.priceRange }),
  ...(e.paymentAccepted?.length && { "paymentAccepted": e.paymentAccepted }),
  ...(e.currenciesAccepted && { "currenciesAccepted": e.currenciesAccepted }),
  ...overrides
});
---

<!-- SEM Structured Data - Declarative JSON-LD Injection -->
{cfg.output.emitJSONLD && cfg.schemas.includeOrganization && (
  <>
    {cfg.output.commentLabels && <!-- Organization Schema -->}
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(
        generateOrganizationSchema(cfg.entity, cfg.schemas.organization), 
        null, 
        cfg.output.prettyPrint ? 2 : 0
      )} 
    />
  </>
)}

{cfg.output.emitJSONLD && cfg.schemas.includeWebsite && (
  <>
    {cfg.output.commentLabels && <!-- Website Schema -->}
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(
        generateWebsiteSchema(cfg.entity, cfg.schemas.website), 
        null, 
        cfg.output.prettyPrint ? 2 : 0
      )} 
    />
  </>
)}

{cfg.output.emitJSONLD && cfg.schemas.includeService && (
  <>
    {cfg.output.commentLabels && <!-- Service Schema -->}
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(
        generateServiceSchema(cfg.entity, cfg.schemas.service), 
        null, 
        cfg.output.prettyPrint ? 2 : 0
      )} 
    />
  </>
)}

{cfg.output.emitJSONLD && cfg.schemas.includeFAQ && cfg.entity.faq?.length && (
  <>
    {cfg.output.commentLabels && <!-- FAQ Schema -->}
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(
        generateFAQSchema(cfg.entity.faq, cfg.schemas.faq), 
        null, 
        cfg.output.prettyPrint ? 2 : 0
      )} 
    />
  </>
)}

{cfg.output.emitJSONLD && cfg.schemas.includeLocalBusiness && (
  <>
    {cfg.output.commentLabels && <!-- Local Business Schema -->}
    <script 
      type="application/ld+json" 
      set:html={JSON.stringify(
        generateLocalBusinessSchema(cfg.entity, cfg.schemas.localBusiness), 
        null, 
        cfg.output.prettyPrint ? 2 : 0
      )} 
    />
  </>
)}

{cfg.output.emitJSONLD && cfg.schemas.additionalSchemas?.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema, null, cfg.output.prettyPrint ? 2 : 0)} />
))}
---
// src/components/GA4.astro
import g4AnalyticsConfig from '../../data/marketing/g4-analytics-config.json';

interface Props {
  id: string;
  config?: GA4Config;
  autoTrack?: AutoTrackConfig;
  userProperties?: Record<string, string>;
  customDimensions?: Record<string, string>;
  customMetrics?: Record<string, number>;
}

// Declarative configuration types
type GA4Config = {
  send_page_view?: boolean;
  ecommerce?: { enabled: boolean; currency?: string };
  enhanced_measurement?: boolean | EnhancedMeasurementConfig;
  link_attribution?: boolean;
  debug_mode?: boolean;
  sample_rate?: number;
  site_speed_sample_rate?: number;
  allow_google_signals?: boolean;
  allow_ad_personalization_signals?: boolean;
  cookie_flags?: string;
  [key: string]: unknown;
};

type EnhancedMeasurementConfig = {
  page_visibility?: boolean;
  scrolls?: boolean;
  outbound_clicks?: boolean;
  page_changes?: boolean;
  searches?: boolean;
  video_engagement?: boolean;
  file_downloads?: boolean;
  form_interactions?: boolean;
};

type AutoTrackConfig = {
  visibility?: boolean;
  scroll?: boolean | { milestones: number[] };
  outboundLinks?: boolean;
  downloads?: boolean | { extensions: string[] };
  forms?: boolean;
  videos?: boolean;
  errors?: boolean;
  performance?: boolean;
  coreWebVitals?: boolean;
};

// Merge props with sensible defaults loaded from JSON (declarative, not imperative)
const {
  id,
  config = {},
  autoTrack = g4AnalyticsConfig.defaultAutoTrack,
  userProperties = g4AnalyticsConfig.defaultUserProperties,
  customDimensions = g4AnalyticsConfig.defaultCustomDimensions,
  customMetrics = g4AnalyticsConfig.defaultCustomMetrics
} = Astro.props;

// Build final config declaratively
const gaConfig = {
  ...g4AnalyticsConfig.defaultConfig,
  custom_map: { ...customDimensions, ...customMetrics },
  ...config,
  ...(config.ecommerce && { currency: config.ecommerce.currency || 'VES' })
};
---

<!-- Google Analytics 4 - Declarative Injection -->
<script is:inline define:vars={{ id, gaConfig, autoTrack, userProperties }}>
  // ─────────────────────────────────────────────────────────────
  // 1. INIT (Declarative bootstrap)
  // ─────────────────────────────────────────────────────────────
  window.dataLayer = window.dataLayer || [];
  const gtag = (...args) => dataLayer.push(args);
  
  gtag('js', new Date());
  gtag('config', id, gaConfig);

  // ─────────────────────────────────────────────────────────────
  // 2. FEATURE TOGGLES (Declarative feature activation)
  // ─────────────────────────────────────────────────────────────
  const features = {
    enhanced_measurement: gaConfig.enhanced_measurement,
    link_attribution: gaConfig.link_attribution,
    ecommerce: gaConfig.ecommerce?.enabled,
    debug_mode: gaConfig.debug_mode
  };

  Object.entries(features).forEach(([feature, enabled]) => {
    if (enabled) gtag('config', id, { [feature]: enabled === true ? {} : enabled });
  });

  // ─────────────────────────────────────────────────────────────
  // 3. TRACKING API (Declarative, chainable, extensible)
  // ─────────────────────────────────────────────────────────────
  const track = {
    base: (name, params = {}) => gtag('event', name, { 
      event_category: params.category || 'engagement',
      event_label: params.label || '',
      value: params.value || 0,
      non_interaction: params.nonInteraction ?? false,
      ...params 
    }),

    pageView: (p = {}) => gtag('config', id, {
      page_title: p.title || document.title,
      page_location: p.location || location.href,
      page_referrer: p.referrer || document.referrer
    }),

    userProp: (name, value) => gtag('config', id, { custom_map: { [name]: value } }),

    ecommerce: (event, data) => gtag('event', event, { 
      ecommerce: data, 
      currency: gaConfig.ecommerce?.currency || 'VES' 
    }),

    conversion: (id, value = 0, currency = 'VES') => 
      gtag('event', 'conversion', { send_to: id, value, currency, ...gaConfig.conversion }),

    timing: (cat, name, val, label = '') => 
      gtag('event', 'timing_complete', { 
        event_category: cat, name, value: Math.round(val), event_label: label 
      }),

    exception: (desc, fatal = false) => 
      gtag('event', 'exception', { description: desc, fatal }),

    social: (network, action, target) => 
      gtag('event', 'social_share', { 
        social_network: network, social_action: action, social_target: target 
      }),

    search: (term, cat = 'site_search') => 
      gtag('event', 'search', { search_term: term, event_category: cat }),

    video: (action, url, title, percent = 0) => 
      gtag('event', `video_${action}`, {
        video_url: url, video_title: title, video_percent: percent,
        video_provider: 'CrediScore', event_category: 'video_engagement'
      }),

    download: (url, name, ext) => 
      gtag('event', 'file_download', {
        file_url: url, file_name: name, file_extension: ext,
        link_url: url, link_text: name, event_category: 'engagement'
      }),

    form: (name, formId, action = 'submit') => 
      gtag('event', `form_${action}`, {
        form_name: name, form_id: formId, 
        form_destination: location.href, event_category: 'form_engagement'
      }),

    scroll: (pct) => gtag('event', 'scroll', { 
      percent_scrolled: pct, event_category: 'engagement' 
    }),

    visibility: (state) => gtag('event', 'page_view', {
      page_location: location.href, visibility_state: state, 
      event_category: 'engagement'
    }),

    outbound: (url, text, domain) => 
      gtag('event', 'click', {
        link_url: url, link_text: text, link_domain: domain,
        outbound: true, event_category: 'outbound'
      }),

    // Aliases for backward compatibility
    event: function(name, p) { return this.base(name, p); },
    engagement: function(action, cat, label, val = 0) { 
      return this.base('engagement', { category: cat, label, value: val, custom_parameter_1: action }); 
    },
    setCustomDimension: function(n, v) { this.userProp(n, v); },
    setCustomMetric: function(n, v) { this.userProp(n, v); }
  };

  // Expose API globally (same as original)
  window.g4a = track;

  // ─────────────────────────────────────────────────────────────
  // 4. AUTO-TRACKERS (Declarative registration pattern)
  // ─────────────────────────────────────────────────────────────
  const autoTrackers = {
    visibility: () => {
      document.addEventListener('visibilitychange', () => 
        track.visibility(document.hidden ? 'hidden' : 'visible')
      );
    },

    scroll: (cfg) => {
      let max = 0;
      const milestones = cfg?.milestones || [25, 50, 75, 90, 100];
      window.addEventListener('scroll', () => {
        const maxScroll = document.documentElement.scrollHeight - innerHeight;
        const pct = Math.round((pageYOffset / maxScroll) * 100);
        milestones.forEach(m => {
          if (pct >= m && max < m) { track.scroll(m); max = m; }
        });
      });
    },

    outboundLinks: () => {
      document.addEventListener('click', (e) => {
        const a = e.target?.closest('a');
        if (!a?.href) return;
        const [cur, tgt] = [location.hostname, new URL(a.href).hostname];
        if (cur !== tgt) track.outbound(a.href, a.textContent?.trim() || '', tgt);
      });
    },

    downloads: (cfg) => {
      const exts = cfg?.extensions || [];
      document.addEventListener('click', (e) => {
        const a = e.target?.closest('a');
        if (!a?.href) return;
        const href = a.href.toLowerCase();
        const hasExt = exts.some(ext => href.includes(ext));
        const hasAttr = a.hasAttribute('download');
        if (hasExt || hasAttr) {
          const name = a.getAttribute('download') || a.textContent?.trim() || '';
          const ext = href.split('.').pop() || '';
          track.download(a.href, name, ext);
        }
      });
    },

    forms: () => {
      document.addEventListener('submit', (e) => {
        const f = e.target;
        track.form(
          f.getAttribute('data-name') || f.name || 'unnamed_form',
          f.id || '', 'submit'
        );
      });
    },

    videos: () => {
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('video').forEach(video => {
          let played = false, quartiles = [false, false, false, false];
          const onQuartile = (p, idx) => {
            if (!quartiles[idx]) {
              track.video(`quartile_${idx+1}`, video.currentSrc, video.title || 'Untitled', p);
              quartiles[idx] = true;
            }
          };
          video.addEventListener('play', () => {
            if (!played) { track.video('start', video.currentSrc, video.title || 'Untitled'); played = true; }
          });
          video.addEventListener('timeupdate', () => {
            const pct = Math.round((video.currentTime / video.duration) * 100);
            if (pct >= 25) onQuartile(25, 0);
            if (pct >= 50) onQuartile(50, 1);
            if (pct >= 75) onQuartile(75, 2);
            if (pct >= 100) onQuartile(100, 3);
          });
          video.addEventListener('pause', () => {
            if (video.currentTime > 0 && !video.ended) 
              track.video('pause', video.currentSrc, video.title || 'Untitled');
          });
          video.addEventListener('ended', () => 
            track.video('complete', video.currentSrc, video.title || 'Untitled', 100)
          );
        });
      });
    },

    errors: () => {
      window.addEventListener('error', (e) => track.exception(e.message, false));
    },

    performance: () => {
      window.addEventListener('load', () => {
        if (!performance?.getEntriesByType) return;
        const [nav] = performance.getEntriesByType('navigation') || [];
        if (!nav) return;
        track.timing('page_load', 'load_time', nav.loadEventEnd - nav.navigationStart);
        track.timing('dom_interactive', 'dom_interactive', nav.domInteractive - nav.navigationStart);
        const [fcp] = performance.getEntriesByType('paint')
          .filter(e => e.name === 'first-contentful-paint') || [];
        if (fcp) track.timing('first_contentful_paint', 'fcp', fcp.startTime);
      });
    },

    coreWebVitals: () => {
      if (!('PerformanceObserver' in window)) return;
      
      // LCP
      new PerformanceObserver((list) => {
        const entries = list.getEntries();
        const last = entries[entries.length - 1];
        if (last) track.timing('lcp', 'largest_contentful_paint', last.startTime);
      }).observe({ entryTypes: ['largest-contentful-paint'] });

      // FID
      new PerformanceObserver((list) => {
        const [entry] = list.getEntries();
        if (entry) track.timing('fid', 'first_input_delay', entry.processingStart - entry.startTime);
      }).observe({ entryTypes: ['first-input'] });

      // CLS
      let cls = 0;
      new PerformanceObserver((list) => {
        for (const entry of list.getEntries()) {
          if (!entry.hadRecentInput) cls += entry.value;
        }
        track.timing('cls', 'cumulative_layout_shift', Math.round(cls * 1000));
      }).observe({ entryTypes: ['layout-shift'] });
    }
  };

  // ─────────────────────────────────────────────────────────────
  // 5. ACTIVATE AUTO-TRACKERS (Declarative, opt-in)
  // ─────────────────────────────────────────────────────────────
  Object.entries(autoTrack).forEach(([key, enabled]) => {
    if (enabled && autoTrackers[key]) {
      autoTrackers[key](enabled === true ? undefined : enabled);
    }
  });

  // ─────────────────────────────────────────────────────────────
  // 6. SET USER PROPERTIES (Declarative batch set)
  // ─────────────────────────────────────────────────────────────
  Object.entries(userProperties).forEach(([k, v]) => track.userProp(k, v));
</script>
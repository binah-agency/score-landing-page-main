---
// src/components/AEOContent.astro
import aeoContentConfig from '../../data/marketing/aeo-content-config.json';

interface Props {
  content?: AEOContent;
  metadata?: AEOMetadata;
  output?: AEOOutputConfig;
}

// Declarative content types
type FAQItem = {
  question: string;
  answer: string;
  category?: string;
  keywords?: string[];
};

type HowToItem = {
  name: string;
  description?: string;
  steps: Array<string | { text: string; tip?: string }>;
  estimatedTime?: string;
  supplies?: string[];
};

type DefinitionItem = {
  term: string;
  definition: string;
  alternateNames?: string[];
  url?: string;
};

type AEOContent = {
  faq?: FAQItem[];
  howTo?: HowToItem[];
  definitions?: DefinitionItem[];
};

type AEOMetadata = {
  headline?: string;
  description?: string;
  articleBody?: string;
  author?: string;
  publisher?: string;
  datePublished?: string;
  keywords?: string[];
};

type AEOOutputConfig = {
  emitFAQ?: boolean;
  emitHowTo?: boolean;
  emitDefinitions?: boolean;
  emitArticle?: boolean;
  prettyPrint?: boolean;
};

// Default configuration loaded from JSON (declarative, easily overrideable)
const defaultContent: AEOContent = aeoContentConfig.defaultContent;

const defaultMetadata: AEOMetadata = aeoContentConfig.defaultMetadata;

const defaultOutput: AEOOutputConfig = aeoContentConfig.defaultOutput;

// Merge props with defaults (declarative, immutable)
const {
  content = {},
  metadata = {},
  output = {}
} = Astro.props;

const merged = {
  content: { ...defaultContent, ...content },
  metadata: { ...defaultMetadata, ...metadata },
  output: { ...defaultOutput, ...output }
};

// ─────────────────────────────────────────────────────────────
// JSON-LD Generators (Pure, declarative functions)
// ─────────────────────────────────────────────────────────────
const escapeJSON = (str: string) => 
  str.replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '');

const generateFAQ = (items: FAQItem[]) => ({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(q => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": q.answer
    },
    ...(q.keywords?.length && { "keywords": q.keywords.join(", ") })
  }))
});

const generateHowTo = (items: HowToItem[]) => items.map(h => ({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": h.name,
  ...(h.description && { "description": h.description }),
  ...(h.estimatedTime && { "totalTime": h.estimatedTime }),
  ...(h.supplies?.length && { "tool": h.supplies.map(s => ({ "@type": "HowToSupply", "name": s })) }),
  "step": h.steps.map((s, i) => {
    const step = typeof s === 'string' ? { text: s } : s;
    return {
      "@type": "HowToStep",
      "position": i + 1,
      "text": step.text,
      ...(step.tip && { "itemListElement": { "@type": "HowToTip", "text": step.tip } })
    };
  })
}));

const generateDefinitions = (items: DefinitionItem[]) => items.map(d => ({
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": d.term,
  "description": d.definition,
  ...(d.alternateNames?.length && { "alternateName": d.alternateNames }),
  ...(d.url && { "url": d.url })
}));

const generateArticle = (meta: AEOMetadata, howTo?: HowToItem[], definitions?: DefinitionItem[]) => ({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.headline,
  "description": meta.description,
  "articleBody": meta.articleBody,
  ...(meta.author && { "author": { "@type": "Organization", "name": meta.author } }),
  ...(meta.publisher && { "publisher": { "@type": "Organization", "name": meta.publisher } }),
  ...(meta.datePublished && { "datePublished": meta.datePublished }),
  ...(meta.keywords?.length && { "keywords": meta.keywords.join(", ") }),
  ...(howTo?.[0] && { "howTo": generateHowTo([howTo[0]])[0] }),
  ...(definitions?.length && { "definedTerm": generateDefinitions(definitions) })
});
---

<!-- AEO Structured Data - Declarative JSON-LD Injection -->
{merged.output.emitFAQ && merged.content.faq?.length && (
  <script type="application/ld+json" set:html={JSON.stringify(generateFAQ(merged.content.faq), null, merged.output.prettyPrint ? 2 : 0)} />
)}

{merged.output.emitHowTo && merged.content.howTo?.length && (
  <script type="application/ld+json" set:html={JSON.stringify(generateHowTo(merged.content.howTo), null, merged.output.prettyPrint ? 2 : 0)} />
)}

{merged.output.emitDefinitions && merged.content.definitions?.length && (
  <script type="application/ld+json" set:html={JSON.stringify(generateDefinitions(merged.content.definitions), null, merged.output.prettyPrint ? 2 : 0)} />
)}

{merged.output.emitArticle && (
  <script type="application/ld+json" set:html={JSON.stringify(generateArticle(merged.metadata, merged.content.howTo, merged.content.definitions), null, merged.output.prettyPrint ? 2 : 0)} />
)}
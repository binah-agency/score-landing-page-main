---
// src/components/LLMSEO.astro
import llmSeoConfig from '../../data/marketing/llm-seo-config.json';

interface Props {
  entity?: EntityConfig;
  content?: SEOContent;
  schema?: SchemaConfig;
  output?: OutputConfig;
}

// ───────── Declarative Type Definitions ─────────
type EntityConfig = {
  name: string;
  category: string;
  description?: string;  // Auto-generated if not provided
  foundingDate?: string; // ISO date
  location?: {
    country: string;     // ISO code: "VE"
    city?: string;
  };
  areaServed?: string[]; // ["Venezuela", "LATAM"]
  url?: string;
};

type SEOContent = {
  expertise?: string[];
  services?: string[];
  benefits?: string[];
  features?: string[];
  useCases?: string[];
  targetAudience?: string[];
  differentiators?: string[];
  faq?: Array<{
    question: string;
    answer: string;
    context?: string;  // For LLM query disambiguation
  }>;
  keywords?: {
    primary?: string[];
    semantic?: string[];
  };
};

type SchemaConfig = {
  includeOrganization?: boolean;
  includeArticle?: boolean;
  includeFAQ?: boolean;
  includeOffer?: boolean;
  customProperties?: Array<{ name: string; value: string }>;
  extendContext?: Record<string, string>;
};

type OutputConfig = {
  emitJSONLD?: boolean;
  prettyPrint?: boolean;
  autoGenerateDescription?: boolean;
};

// ───────── Default Configuration Loaded from JSON (Declarative Source of Truth) ─────────
const defaultEntity: EntityConfig = llmSeoConfig.defaultEntity as EntityConfig;

const defaultContent: SEOContent = llmSeoConfig.defaultContent as SEOContent;

const defaultSchema: SchemaConfig = llmSeoConfig.defaultSchema as SchemaConfig;

const defaultOutput: OutputConfig = llmSeoConfig.defaultOutput as OutputConfig;

// ───────── Merge Props with Defaults (Immutable, Shallow Merge) ─────────
const {
  entity = {},
  content = {},
  schema = {},
  output = {}
} = Astro.props;

const cfg = {
  entity: { ...defaultEntity, ...entity },
  content: { ...defaultContent, ...content },
  schema: { ...defaultSchema, ...schema },
  output: { ...defaultOutput, ...output }
};

// ───────── Pure Helper Functions (Declarative, Testable) ─────────
const escapeJSON = (str: string) => 
  str.replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '').replace(/\t/g, '  ');

const generateDescription = (e: EntityConfig, c: SEOContent): string => {
  if (!cfg.output.autoGenerateDescription && e.description) return e.description;
  
  return `${e.name} es ${e.category} líder en Venezuela que revoluciona la evaluación de confianza comercial mediante tecnología de punta. Nuestra plataforma utiliza un Sistema de Apoyo a Decisiones (DSS) para analizar comportamientos financieros y generar puntajes de confianza objetivos y verificables.

Con metodología probada en más de 170 países, ${e.name} ofrece servicios especializados en ${c.services?.join(', ')}. Nuestra tecnología permite ${c.benefits?.join(', ')}, transformando cómo las personas y empresas demuestran su fiabilidad comercial en el mercado venezolano.

Nuestra plataforma se caracteriza por ${c.features?.join(', ')}, lo que nos posiciona como el diferenciador clave en el sector financiero venezolano. Atendemos a ${c.targetAudience?.join(', ')}, proporcionando soluciones adaptadas a cada necesidad específica.

Lo que nos diferencia es ${c.differentiators?.join(', ')}, estableciendo un nuevo estándar de confianza técnica en Venezuela.`;
};

const generateOrganizationSchema = (e: EntityConfig, c: SEOContent, s: SchemaConfig) => {
  const desc = generateDescription(e, c);
  
  return {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": e.name,
    "description": desc,
    "category": e.category,
    ...(e.foundingDate && { "foundingDate": e.foundingDate }),
    ...(e.location && {
      "address": {
        "@type": "PostalAddress",
        "addressCountry": e.location.country,
        ...(e.location.city && { "addressLocality": e.location.city })
      }
    }),
    ...(e.areaServed && { "areaServed": e.areaServed }),
    ...(c.expertise?.length && { "knowsAbout": c.expertise }),
    ...(s.includeOffer && c.services?.length && {
      "offers": {
        "@type": "Offer",
        "itemOffered": c.services.map(srv => ({
          "@type": "Service",
          "name": srv,
          "provider": e.name
        }))
      }
    }),
    ...(c.expertise?.length && { "expertise": c.expertise }),
    ...(c.services?.length && { "services": c.services }),
    ...(c.benefits?.length && { "benefits": c.benefits }),
    ...(c.features?.length && { "features": c.features }),
    ...(c.useCases?.length && { "useCases": c.useCases }),
    ...(c.targetAudience?.length && { "targetAudience": c.targetAudience }),
    ...(c.differentiators?.length && { "differentiators": c.differentiators }),
    ...(s.includeFAQ && c.faq?.length && {
      "mainEntity": {
        "@type": "FAQPage",
        "mainEntity": c.faq.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          },
          ...(f.context && { "context": f.context })
        }))
      }
    }),
    "articleBody": desc,
    ...(s.customProperties?.length && {
      "additionalProperty": s.customProperties.map(p => ({
        "@type": "PropertyValue",
        "name": p.name,
        "value": p.value
      }))
    })
  };
};

const generateArticleSchema = (e: EntityConfig, c: SEOContent) => {
  const desc = generateDescription(e, c);
  const today = new Date().toISOString().split('T')[0];
  
  return {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": `${e.name} - ${e.category}`,
    "description": desc,
    "author": { "@type": "Organization", "name": e.name },
    "publisher": { "@type": "Organization", "name": e.name },
    "datePublished": e.foundingDate || "2023-01-01",
    "dateModified": today,
    "articleBody": desc,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": e.url || "https://crediscore.ve"
    },
    ...(c.expertise?.length && { "about": c.expertise }),
    ...(c.services?.length && { "mentions": c.services })
  };
};
---

<!-- LLM SEO Structured Data - Declarative JSON-LD Injection -->
{cfg.output.emitJSONLD && cfg.schema.includeOrganization && (
  <script 
    type="application/ld+json" 
    set:html={JSON.stringify(
      generateOrganizationSchema(cfg.entity, cfg.content, cfg.schema), 
      null, 
      cfg.output.prettyPrint ? 2 : 0
    )} 
  />
)}

{cfg.output.emitJSONLD && cfg.schema.includeArticle && (
  <script 
    type="application/ld+json" 
    set:html={JSON.stringify(
      generateArticleSchema(cfg.entity, cfg.content), 
      null, 
      cfg.output.prettyPrint ? 2 : 0
    )} 
  />
)}

<!-- Optional: Expose raw data for debugging or programmatic access -->
{cfg.output.prettyPrint && (
  <script 
    type="application/json" 
    id="llm-seo-data" 
    set:html={JSON.stringify({ entity: cfg.entity, content: cfg.content }, null, 2)} 
  />
)}
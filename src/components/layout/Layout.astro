---
// Layout Component - Decoupled layout wrapper
import ThemeProvider from '../ui/design-system/ThemeProvider.astro';

interface Props {
  children: any;
  className?: string;
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'full';
  padding?: 'sm' | 'md' | 'lg' | 'xl';
  centered?: boolean;
}

const { 
  children, 
  className = '', 
  maxWidth = 'xl',
  padding = 'md',
  centered = true 
} = Astro.props;

const maxWidthClasses = {
  sm: 'max-w-sm',
  md: 'max-w-md', 
  lg: 'max-w-lg',
  xl: 'max-w-xl',
  '2xl': 'max-w-2xl',
  '3xl': 'max-w-3xl',
  '4xl': 'max-w-4xl',
  '5xl': 'max-w-5xl',
  '6xl': 'max-w-6xl',
  '7xl': 'max-w-7xl',
  full: 'max-w-full'
};

const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
  xl: 'p-12'
};

const centeredClasses = centered ? 'mx-auto' : '';
---

<ThemeProvider>
  <div 
    class={[
      'w-full',
      maxWidthClasses[maxWidth],
      paddingClasses[padding],
      centeredClasses,
      className
    ].join(' ')}
  >
    {children}
  </div>
</ThemeProvider>

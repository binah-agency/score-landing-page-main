---
// Grid Component - Flexible grid system
interface Props {
  children: any;
  cols?: 1 | 2 | 3 | 4 | 5 | 6 | 12;
  sm?: 1 | 2 | 3 | 4 | 5 | 6 | 12;
  md?: 1 | 2 | 3 | 4 | 5 | 6 | 12;
  lg?: 1 | 2 | 3 | 4 | 5 | 6 | 12;
  xl?: 1 | 2 | 3 | 4 | 5 | 6 | 12;
  gap?: 'none' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl';
  className?: string;
  as?: 'div' | 'section' | 'main' | 'article' | 'aside' | 'footer' | 'header' | 'nav';
}

const { 
  children, 
  cols = 1,
  sm,
  md,
  lg,
  xl,
  gap = 'md',
  className = '',
  as: Tag = 'div'
} = Astro.props;

const colsClasses = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  5: 'grid-cols-5',
  6: 'grid-cols-6',
  12: 'grid-cols-12'
};

const smColsClasses = sm ? colsClasses[sm] : '';
const mdColsClasses = md ? `md:${colsClasses[md]}` : '';
const lgColsClasses = lg ? `lg:${colsClasses[lg]}` : '';
const xlColsClasses = xl ? `xl:${colsClasses[xl]}` : '';

const gapClasses = {
  none: 'gap-0',
  sm: 'gap-2',
  md: 'gap-4',
  lg: 'gap-6',
  xl: 'gap-8',
  '2xl': 'gap-10',
  '3xl': 'gap-12'
};
---

<Tag
  class={[
    'grid',
    colsClasses[cols],
    smColsClasses,
    mdColsClasses,
    lgColsClasses,
    xlColsClasses,
    gapClasses[gap],
    className
  ].join(' ')}
>
  {children}
</Tag>

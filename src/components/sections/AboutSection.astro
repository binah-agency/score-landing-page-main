---

import iconWorld from '../../assest/about/icon-world.svg?url';
import iconStar from '../../assest/about/icon-star.svg?url';
import iconCheckbox from '../../assest/about/icon-checkbox.svg?url';
import aboutData from '../../data/content.about.json';
import SectionTitle from '../ui/atoms/SectionTitle.astro';
import DecorativeCircles from '../ui/atoms/DecorativeCircles.astro';
import WorldMap from '../ui/atoms/WorldMap.astro';
import CarouselSlide from '../ui/atoms/CarouselSlide.astro';
import FeatureItem from '../ui/molecules/FeatureItem.astro';
import AboutCarousel from '../ui/molecules/AboutCarousel.astro';
import FeatureGrid from '../ui/molecules/FeatureGrid.astro';
const { section } = aboutData;
---

<section class="relative flex align-center mx-auto h-fit w-full max-w-[1920px]" id={section.id}>
  <div class="relative w-full h-[700px] my-10 sticky top-0 z-10">
    <!-- Título -->
    <SectionTitle title={section.title} variant="desktop" />
    <div class="relative h-full w-full grid justify-center vertical-center grid-cols-2">
      <!-- Scroll Container (izquierda) -->
      <div class="relative h-fit w-[90%] bg-blue-500 items-center justify-center align-middle justify-items-center rounded-br-[300px] rounded-tr-[300px] bg-[var(--color-azulhorizonte)] p-[10px]" style={{ top: '120px' }}  >
        <div class="flex w-[550px] flex-col items-start p-[10px]">
          <!-- Text Scroll -->
          <div class="relative h-[277px] w-full overflow-hidden ">
            <div id="about-carousel" class="absolute left-0 top-0 flex h-[241px] items-center gap-[68px] transition-transform duration-500 ease-in-out">
              <CarouselSlide title="Misión" content={section.mission} variant="desktop" />
              <CarouselSlide title="Visión" content={section.vision} variant="desktop" />
              <CarouselSlide title="Valores" content={section.values.map(value => value.title).join(' · ')} variant="desktop" />
            </div>
            <!-- Scroll Selector -->
            <div class="absolute bottom-[27px] left-1/2 flex -translate-x-1/2 items-center gap-[7px] ">
              <button id="dot-0" class="about-dot h-4 w-[62px] rounded-[24px] bg-[var(--color-verdevitalidad)] transition-all duration-300" aria-label="Slide 1"></button>
              <button id="dot-1" class="about-dot h-4 w-[62px] rounded-[24px] border border-white transition-all duration-300" aria-label="Slide 2"></button>
              <button id="dot-2" class="about-dot h-4 w-[62px] rounded-[24px] border border-white transition-all duration-300" aria-label="Slide 3"></button>
            </div>
          </div>
        </div>
      </div>
      <!-- Contenedor derecho: Globo + Items -->
      <div class="relative h-auto w-fit ">
        <!-- Círculos decorativos -->
        <DecorativeCircles />

        <!-- Mundo/Globo -->
        <WorldMap />

        <!-- Item: Tecnología de Clase Mundial -->
        <FeatureItem 
          feature={section.features[0]} 
          icon="world" 
          position={{ left: "left-[-120px]", top: "top-10" }} 
          width="w-[604px]" 
        />

        <!-- Item: Pioneros en Venezuela -->
        <FeatureItem 
          feature={section.features[1]} 
          icon="star" 
          position={{ left: "left-[10px]", top: "top-[185px]" }}
          width="w-[379px]" 
        />

        <!-- Item: Tu Identidad de Confianza -->
        <FeatureItem 
          feature={section.features[2]} 
          icon="checkbox" 
          position={{ left: "left-[30px]", top: "top-[350px]" }} 
          width="w-[377px]" 
        />
      </div>
    </div>
  </div>

</section>

<!-- Versión Tablet -->
<section class="relative mx-auto hidden h-auto min-h-[800px] w-full max-w-[1920px] bg-[var(--color-black)] px-5 py-16 md:block lg:hidden" id="nosotros-tablet">
  <!-- Título -->
  <SectionTitle title={section.title} variant="tablet" />

  <!-- Carousel -->
  <AboutCarousel 
    mission={section.mission}
    vision={section.vision}
    values={section.values.map(value => value.title)}
    carouselId="tablet-carousel"
    dotsId="tablet-dots"
    dotClass="tablet-dot"
    variant="tablet"  
  />

  <!-- Feature Grid -->
  <FeatureGrid 
    features={section.features}
    iconWorld={iconWorld}
    iconStar={iconStar}
    iconCheckbox={iconCheckbox}
  />
</section>

<!-- Versión Mobile -->
<section class="relative mx-auto block w-full bg-[var(--color-black)] px-5 py-12 md:hidden" id="nosotros-mobile">
  <!-- Título -->
  <SectionTitle title={section.title} variant="mobile" />

  <!-- Carousel -->
  <AboutCarousel 
    mission={section.mission}
    vision={section.vision}
    values={section.values.map(value => value.title)}
    carouselId="mobile-carousel"
    dotsId="mobile-dots"
    dotClass="mobile-dot"
    variant="mobile"
  />

  <!-- Feature Grid -->
  <FeatureGrid 
    features={section.features}
    iconWorld={iconWorld}
    iconStar={iconStar}
    iconCheckbox={iconCheckbox}
    className="grid-cols-1 gap-6"
  />
</section>

<style>
  /* Desktop only */
  @media (max-width: 1023px) {
    #nosotros {
      display: none;
    }
  }
  @media (min-width: 1024px) {
    #nosotros-tablet,
    #nosotros-mobile {
      display: none !important;
    }
  }
</style>

<script>
  // About Section Carousel - Desktop
  const desktopCarousel = document.getElementById('about-carousel');
  const desktopDots = document.querySelectorAll('.about-dot');
  const desktopSlideWidth = 530 + 68; // width + gap
  
  // About Section Carousel - Tablet
  const tabletCarousel = document.getElementById('tablet-carousel');
  const tabletDots = document.querySelectorAll('.tablet-dot');
  
  // About Section Carousel - Mobile
  const mobileCarousel = document.getElementById('mobile-carousel');
  const mobileDots = document.querySelectorAll('.mobile-dot');
  
  let currentSlide = 0;
  const totalSlides = 3;
  let autoplayInterval: ReturnType<typeof setInterval>;

  function goToSlide(index: number) {
    currentSlide = index;
    
    // Update desktop carousel
    if (desktopCarousel) {
      desktopCarousel.style.transform = `translateX(-${currentSlide * desktopSlideWidth}px)`;
    }
    
    // Update tablet carousel
    if (tabletCarousel) {
      tabletCarousel.style.transform = `translateX(-${currentSlide * 100}%)`;
    }
    
    // Update mobile carousel
    if (mobileCarousel) {
      mobileCarousel.style.transform = `translateX(-${currentSlide * 100}%)`;
    }
    
    // Update desktop dots
    desktopDots.forEach((dot, i) => {
      if (i === currentSlide) {
        dot.classList.remove('border', 'border-white');
        dot.classList.add('bg-[var(--color-verdevitalidad)]');
      } else {
        dot.classList.remove('bg-[var(--color-verdevitalidad)]');
        dot.classList.add('border', 'border-white');
      }
    });
    
    // Update tablet dots
    tabletDots.forEach((dot, i) => {
      if (i === currentSlide) {
        dot.classList.remove('border', 'border-white');
        dot.classList.add('bg-[var(--color-verdevitalidad)]');
      } else {
        dot.classList.remove('bg-[var(--color-verdevitalidad)]');
        dot.classList.add('border', 'border-white');
      }
    });
    
    // Update mobile dots
    mobileDots.forEach((dot, i) => {
      if (i === currentSlide) {
        dot.classList.remove('border', 'border-white');
        dot.classList.add('bg-[var(--color-verdevitalidad)]');
      } else {
        dot.classList.remove('bg-[var(--color-verdevitalidad)]');
        dot.classList.add('border', 'border-white');
      }
    });
  }

  function nextSlide() {
    const next = (currentSlide + 1) % totalSlides;
    goToSlide(next);
  }

  // Click events for desktop dots
  desktopDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      goToSlide(index);
      resetAutoplay();
    });
  });

  // Click events for tablet dots
  tabletDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      goToSlide(index);
      resetAutoplay();
    });
  });

  // Click events for mobile dots
  mobileDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      goToSlide(index);
      resetAutoplay();
    });
  });

  function resetAutoplay() {
    clearInterval(autoplayInterval);
    autoplayInterval = setInterval(nextSlide, 4000);
  }

  // Start autoplay
  autoplayInterval = setInterval(nextSlide, 4000);
</script>


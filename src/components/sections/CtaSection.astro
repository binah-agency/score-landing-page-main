---
import ctaData from '../../data/content/content.cta.json';
import CtaCard from '../ui/molecules/CtaCard.astro';

const { section } = ctaData;
---

<section class="w-full bg-[var(--color-black)]" id={section.id}>
  <div class="mx-auto flex w-full max-w-[1920px] flex-col items-center justify-center gap-[40px] p-[10px] py-[60px]">
    <h2 class="font-montserrat text-[48px] font-bold leading-[48px] text-white">
      {section.title}
    </h2>

    <div class="flex flex-col items-center gap-[45px] px-5 lg:flex-row lg:px-0">
      {section.cards.map((card) => (
        <CtaCard card={card} />
      ))}
    </div>

    <div class="flex w-[451px] flex-col items-start p-[10px]">
      <a 
        href={section.cta.href}
        aria-label={section.cta.text}
        class="flex h-[50px] w-full items-center justify-center rounded-[8px] bg-[var(--color-verdevitalidad)] p-[10px]"
      >
        <span class="font-montserrat text-[24px] font-semibold text-white">
          {section.cta.text}
        </span>
      </a>
    </div>
  </div>
</section>
---
// FeaturesSection - "Tu Índice de Confianza"

// Content Data
import featuresData from '../../data/content.features.json';

const { section } = featuresData;
---

<section class="relative w-full bg-[#071222]" id={section.id}>
  <div class="relative mx-auto flex w-full max-w-[1920px] flex-col items-center">
    
    <!-- ScoreSection Container -->
    <div class="relative h-[1198px] w-[1776px]">
      
      <!-- Arco semicircular de Score (SVG de Figma) -->
      <!-- Dimensiones: 1794x867, posición: left:-3, top:341 -->
      <div class="absolute left-[-3px] top-[341px] h-[867px] w-[1794px]">
        <img src="/images/score-arc.svg" alt="" class="h-full w-full" />
      </div>

      <!-- Content (tarjetas y texto) - z-index más alto para que esté sobre el arco -->
      <div class="absolute left-[7px] top-0 z-10 flex h-[1198px] w-[1774px] flex-col items-center gap-[462px] py-16">
        
        <!-- CardsContainer - 4 tarjetas -->
        <div class="flex w-full items-start justify-center gap-4">
          
          {section.cards.map((card, index) => (
            <div class={`flex w-auto shrink-0 flex-col items-center gap-6 rounded-[24px] px-3 py-6 ${
              index === 0 ? 'border border-[var(--color-azulhorizonte40)] bg-[var(--color-black)]' : ''
            }`}>
              <!-- TOP -->
              <div class="flex h-[111px] w-full items-start">
                <!-- Icon -->
                <div class="flex items-center p-[10px]">
                  <div class="flex items-center rounded-full p-2" style={`background-color: ${card.iconColor}`}>
                    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="16" cy="14" r="6" stroke="white" stroke-width="2.5"/>
                      <path d="M26 33C26 27.4772 21.5228 23 16 23C10.4772 23 6 27.4772 6 33" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                      <circle cx="30" cy="26" r="5" stroke="white" stroke-width="2.5"/>
                      <path d="M34 31L37 34" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                  </div>
                </div>
                <!-- Container -->
                <div class="flex w-[341px] flex-col items-start pt-4">
                  <!-- Title -->
                  <div class="flex h-[38px] w-full items-center gap-2">
                    <p class="font-montserrat text-[24px] font-bold leading-[64px] text-white">
                      {card.title}
                    </p>
                    <p class="font-montserrat text-[16px] font-medium leading-4 text-[var(--color-azulhorizonte40)]">
                      {card.range}
                    </p>
                  </div>
                  <!-- Párrafo -->
                  <div class="h-[57px] w-full">
                    <p class="flex h-full flex-col justify-center font-montserrat text-[14px] font-medium leading-4 text-[var(--color-azulhorizonte40)]">
                      {card.description}
                    </p>
                  </div>
                </div>
              </div>
              <!-- BOTTOM -->
              <div class="flex h-[51px] w-full flex-col items-start pl-[80px]">
                <p class="font-montserrat text-[14px] font-bold uppercase leading-4 text-[var(--color-verdevitalidad)]">
                  BENEFICIOS
                </p>
                <div class="mt-2">
                  {card.benefits.map((benefit, benefitIndex) => (
                    <p key={benefitIndex} class="font-montserrat text-[14px] font-medium leading-4 text-[var(--color-azulhorizonte40)]">
                      {benefit}
                    </p>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Content inferior (título y descripción) -->
        <div class="flex w-[1125px] flex-col items-center gap-[41px]">
          <!-- Título principal -->
          <div class="relative h-[110px] w-[918px]">
            <p class="absolute left-[84.5px] top-[23px] font-montserrat text-[64px] font-bold leading-[64px] text-white">
              {section.title}
            </p>
          </div>
          
          <!-- Subtítulo y párrafo -->
          <div class="flex w-full flex-col items-start gap-[41px]">
            <div class="flex flex-col items-center justify-center">
              <p class="font-montserrat text-[32px] font-normal leading-8 text-[var(--color-verdevitalidad)]">
                {section.subtitle}
              </p>
            </div>
            <div class="relative h-[112px] w-full">
              <p class="absolute left-0 top-6 font-montserrat text-[24px] font-medium leading-8 text-[var(--color-azulhorizonte40)]">
                {section.description}
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

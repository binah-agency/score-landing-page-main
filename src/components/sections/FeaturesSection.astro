---
// FeaturesSection - "Tu Índice de Confianza"

// Content Data
import featuresData from '../../data/content.features.json';
import ScoreArc from '../ui/atoms/ScoreArc.astro';
import FeatureCard from '../ui/molecules/FeatureCard.astro';
import FeaturesContent from '../ui/molecules/FeaturesContent.astro';

const { section } = featuresData;
---

<section class="relative w-full h-auto bg-[#071222]" id={section.id}>
  <div class="relative mx-auto flex w-full max-w-7xl px-4 sm:px-6 lg:px-8 flex-col items-center">
    
    <!-- ScoreSection Container -->
    <div class="relative w-full h-auto min-h-[600px] lg:min-h-[800px] xl:min-h-[1000px]">
      
      <!-- Arco semicircular de Score (SVG de Figma) -->
      <ScoreArc />

      <!-- Content (tarjetas y texto) - z-index más alto para que esté sobre el arco -->
      <div class="absolute inset-0 z-10 flex h-full w-full flex-col items-center justify-between py-8 sm:py-12 lg:py-16">
        
        <!-- CardsContainer - 4 tarjetas -->
        <div class="flex w-full items-start justify-center gap-2 sm:gap-3 lg:gap-4 flex-wrap lg:flex-nowrap">
          
          {section.cards.map((card, index) => (
            <FeatureCard card={card} isActive={index === 0} />
          ))}
        </div>

        <!-- Content inferior (título y descripción) -->
        <div class="w-full max-w-4xl mx-auto">
          <FeaturesContent 
            title={section.title}
            subtitle={section.subtitle}
            description={section.description}
          />
        </div>

      </div>
    </div>
  </div>
</section>

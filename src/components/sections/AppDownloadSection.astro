---
import appDownloadData from '../../data/content/content.app-download.json';
import socialData from '../../data/content/content.social.json';
import storesData from '../../data/content/content.stores.json';
import AppDownloadContent from '../ui/molecules/AppDownloadContent.astro';
import PhoneMockup from '../ui/atoms/PhoneMockup.astro';

const { section } = appDownloadData;
const phoneMockup = (appDownloadData as Record<string, unknown>).phoneMockup as { src: string; alt: string } | undefined;
---

<section class="w-full bg-[var(--color-azulhorizonte)]" id={section.id}>
  <div class="mx-auto flex w-full max-w-[1920px] items-center justify-center gap-[24px] px-[60px] py-[50px]">
    <AppDownloadContent 
      content={{ title: section.title, subtitle: section.subtitle }}
      socialIcons={socialData.icons}
      storeBadges={storesData.badges}
    />
    <PhoneMockup 
      image={phoneMockup?.src} 
      alt={phoneMockup?.alt} 
    />
  </div>
</section>
---
import coreModulesData from '../../data/content/content.core-modules.json';
import CoreModuleCard from '../ui/molecules/CoreModuleCard.astro';
import CoreModulesContainer from '../ui/molecules/CoreModulesContainer.astro';

const { section } = coreModulesData;
const { empresa, persona } = section.modules;
---

<section class="bg-white px-5 py-16 lg:px-[81px] lg:py-[78px]" id={section.id}>
  <div class="mx-auto flex w-full max-w-[1500px] flex-col items-center gap-[27px]">
    
    <div class="flex w-full flex-col items-start">
      <div class="flex w-full flex-col items-start px-0 text-center capitalize lg:px-[52px]">
        <p class="w-full font-montserrat text-[24px] font-medium leading-[64px] text-[var(--color-azulhorizonte-alt)] md:text-[32px]">
          {section.title.subtitle}
        </p>
        <p class="w-full font-montserrat text-[36px] font-bold leading-[48px] text-[var(--color-black)] md:text-[48px]">
          {section.title.main}
        </p>
      </div>
      <div class="relative h-[112px] w-full">
        <p class="absolute inset-0 flex flex-col justify-center text-center font-montserrat text-[18px] font-medium leading-[28px] text-[var(--color-gray600)] md:text-[20px]">
          {section.description}
        </p>
      </div>
    </div>

    <div class="hidden w-full lg:block">
      <CoreModulesContainer 
        leftModule={empresa} 
        rightModule={persona}
      />
    </div>

    <div class="flex w-full flex-col gap-6 lg:hidden">
      <CoreModuleCard module={empresa} theme="blue" />
      <CoreModuleCard module={persona} theme="green" />
    </div>
  </div>
</section>
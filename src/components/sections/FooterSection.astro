---
import footerData from '../../data/content/content.footer.json';
import SocialLinks from '../ui/atoms/SocialLinks.astro';
import FooterInfo from '../ui/molecules/FooterInfo.astro';
import QuickLinks from '../ui/molecules/QuickLinks.astro';
import CTAButton from '../ui/atoms/CTAButton.astro';

const { footer } = footerData;
---

<footer class="w-full bg-[var(--color-black)] px-[10px] pt-[40px]" id="footer">
  <div class="mx-auto flex w-full max-w-[1065px] flex-col items-center gap-[80px]">
    <div class="grid w-full grid-cols-1 gap-[90px] md:grid-cols-2">
      <div class="flex w-full max-w-[350px] flex-col items-start gap-[37px] justify-self-center">
        <FooterInfo 
          companyName={footer.company.name} 
          description={footer.company.description} 
        />
        <SocialLinks />
      </div>
      
      <div class="flex w-[186px] flex-col items-start gap-[20px] justify-self-center">
        <h3 class="font-montserrat text-[20px] font-extrabold leading-[80px] text-white">
          Enlaces Rápidos
        </h3>
        <QuickLinks links={footer.quickLinks} />
      </div>
    </div>
    
    <div class="flex w-full items-center justify-center gap-[20px] border-b border-t border-[#ccc] py-[40px]">
      <p class="font-montserrat text-[36px] font-extrabold leading-[80px] text-white">
        {footer.cta.title}
      </p>
      <CTAButton href={footer.cta.href} text={footer.cta.buttonText} />
    </div>
  </div>
  
  <div class="flex w-full flex-col items-center py-[40px]">
    <p class="text-center font-montserrat text-[16px] font-medium leading-[28px] text-white">
      {footer.copyright}
    </p>
  </div>
</footer>
---
// FaqSection - Preguntas Frecuentes con acordeón animado
// Estado cerrado: fondo azul, texto blanco, botón + verde
// Estado abierto: fondo blanco, texto azul, botón x azul

const faqs = [
  {
    number: '01',
    question: '¿Que pasa si no tengo historial financiero?',
    answer: 'Sí, la plataforma está diseñada para ayudarte a construir y demostrar tu confiabilidad, incluso si no cuentas con un historial financiero bancario tradicional.',
  },
  {
    number: '02',
    question: '¿Cuanto tiempo tarda en mejorar mi Score de Oportunidad?',
    answer: 'El tiempo que tarda en mejorar tu Score en la plataforma depende directamente del tipo de acciones financieras y de cumplimiento que apliques. A través de la "Guía de Mejora de Score" que ofrece la aplicación, se establecen tiempos estimados según el impacto de cada acción',
  },
  {
    number: '03',
    question: '¿Si mi empresa es nueva ¿puedo acceder a los servicios de sistema operativo de Credi Empresa?',
    answer: 'Sí, una empresa nueva puede acceder a los servicios del Portal Empresarial (Módulo B2B), pero el sistema exige cumplir con ciertos requisitos previos para garantizar la seguridad y operatividad.\n\nUna vez que tu empresa esté registrada, verificada y con su suscripción activa, podrás disfrutar de todo el flujo del Portal Empresarial: buscar usuarios mediante su documento, solicitarles consentimiento para ver su score y estructurar ofertas de crédito',
  },
];
---

<section class="w-full bg-[#4a4a4a] px-[48px] py-[64px]" id="faq">
  <div class="mx-auto flex w-full max-w-[1180px] flex-col items-start overflow-hidden rounded-[40px]">
    {
      faqs.map((faq, index) => (
        <article 
          class="faq-item group w-full cursor-pointer border-b border-[#7a7a7a] last:border-b-0"
          data-index={index}
        >
          <!-- Contenedor principal -->
          <div class="faq-surface flex w-full gap-[52px] bg-[var(--color-azulhorizonte)] px-[60px] py-[52px] transition-colors duration-300">
            <!-- Número -->
            <span class="faq-number font-inter text-[48px] font-bold leading-[1.2] tracking-[0.25px] text-[#a5d470] transition-colors duration-300">
              {faq.number}
            </span>
            
            <!-- Contenido -->
            <div class="flex flex-1 flex-col gap-[24px] pt-[3px]">
              <!-- Header -->
              <div class="flex items-start gap-[16px]">
                <!-- Pregunta -->
                <p class="faq-question flex-1 font-inter text-[32px] font-bold leading-[1.2] text-white transition-colors duration-300">
                  {faq.question}
                </p>
                
                <!-- Botón -->
                <button class="faq-btn flex h-[48px] w-[48px] shrink-0 items-center justify-center rounded-full bg-[var(--color-verdevitalidad)] transition-all duration-300">
                  <span class="faq-icon text-[24px] font-bold text-white transition-transform duration-300">+</span>
                </button>
              </div>
              
              <!-- Respuesta (animación slide down) -->
              <div class="faq-answer grid grid-rows-[0fr] transition-all duration-300 ease-out">
                <div class="overflow-hidden">
                  <p class="font-inter text-[20px] font-normal leading-[1.4] text-[#4a4a4a] whitespace-pre-line pb-2">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  /* Estado abierto */
  .faq-item.open .faq-surface {
    background-color: white;
  }
  
  .faq-item.open .faq-number {
    color: #6a9a35;
  }
  
  .faq-item.open .faq-question {
    color: var(--color-azulhorizonte);
  }
  
  .faq-item.open .faq-btn {
    background-color: var(--color-azulhorizonte-alt);
  }
  
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }
  
  .faq-item.open .faq-answer {
    grid-template-rows: 1fr;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach((item) => {
      item.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        
        // Cerrar todos los demás
        faqItems.forEach((otherItem) => {
          otherItem.classList.remove('open');
        });
        
        // Toggle el actual
        if (!isOpen) {
          item.classList.add('open');
        }
      });
    });
  });
</script>

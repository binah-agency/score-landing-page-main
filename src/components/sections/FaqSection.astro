---
import faqData from '../../data/content/content.faq.json';
import FaqItem from '../ui/molecules/FaqItem.astro';

const { faqs } = faqData;
---

<section class="w-full bg-[#4a4a4a] px-[48px] py-[64px]" id="faq">
  <div class="mx-auto flex w-full max-w-[1180px] flex-col items-start overflow-hidden rounded-[40px]">
    {faqs.map((faq, index) => (
      <FaqItem item={faq} index={index} />
    ))}
  </div>
</section>

<style>
  .faq-item.open .faq-surface {
    background-color: white;
  }
  
  .faq-item.open .faq-number {
    color: #6a9a35;
  }
  
  .faq-item.open .faq-question {
    color: var(--color-azulhorizonte);
  }
  
  .faq-item.open .faq-btn {
    background-color: var(--color-azulhorizonte-alt);
  }
  
  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }
  
  .faq-item.open .faq-answer {
    grid-template-rows: 1fr;
  }
</style>

<script>
  import { gsap } from 'gsap';
  
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');
    const answerElements = document.querySelectorAll('.faq-answer');
    
    if (!faqItems.length || !answerElements.length) return;

    // Set initial state - all answers closed
    answerElements.forEach((answer) => {
      (answer as HTMLElement).style.height = '0px';
      (answer as HTMLElement).style.overflow = 'hidden';
    });

    faqItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        
        // Close all items
        faqItems.forEach((otherItem, otherIndex) => {
          otherItem.classList.remove('open');
          
          // Animate close
          const otherAnswer = answerElements[otherIndex] as HTMLElement;
          gsap.to(otherAnswer, {
            height: 0,
            duration: 0.3,
            ease: 'power2.inOut'
          });
        });
        
        // Toggle current if not open
        if (!isOpen) {
          item.classList.add('open');
          
          // Animate open
          const answer = answerElements[index] as HTMLElement;
          const content = answer.querySelector('div') as HTMLElement;
          const contentHeight = content.scrollHeight;
          
          gsap.to(answer, {
            height: contentHeight + 'px',
            duration: 0.3,
            ease: 'power2.inOut',
            onComplete: () => {
              answer.style.height = 'auto';
            }
          });
        }
      });
    });
  });
</script>
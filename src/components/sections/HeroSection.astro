---
import heroData from '../../data/content.hero.json';
import SmoothScroll from '../ui/atoms/SmoothScroll.astro';
import HeroImage from '../ui/atoms/HeroImage.astro';
import HeroBadge from '../ui/atoms/HeroBadge.astro';
import HeroContent from '../ui/molecules/HeroContent.astro';
import Header from '../ui/organisms/Header.astro';
const { content } = heroData;
---

<section class="hero-section mx-auto flex w-full max-w-[1920px] flex-col items-center gap-10 px-5 pb-[11px] pt-[20px] md:pt-[20px] lg:pt-[60px]">
  <!-- ========== HEADER ========== -->
  <Header /> 

  <!-- Desktop Hero -->
  <div class="relative hidden w-full max-w-[1700px] overflow-hidden rounded-[60px] bg-white lg:block">
    <div class="relative flex h-[775px] w-full items-center justify-end">
      <!-- Hero Image Container -->
      <HeroImage 
        containerClass="relative overflow-hidden h-[775px] w-[907px]"
        screen="desktop"
      />

      <!-- Content Container -->
      <div class="absolute left-10 top-0 flex items-end gap-10 pb-10">
        <!-- Badge rotado "1000+ Clientes" -->
        <HeroBadge text={content.badge.text} />

        <!-- Hero Content -->
        <HeroContent 
          bannerText={content.banner.text}
          taglineLines={content.tagline.lines}
          claimText={content.claim}
          ctaHref={content.cta.href}
          ctaText={content.cta.text}
          screen="desktop"
        />
      </div>
    </div>
  </div>

  <!-- Tablet Hero -->
  <div class="relative hidden  w-full max-w-[831px] overflow-hidden rounded-[60px] mb-10 bg-white md:block lg:hidden">
    <div class="relative flex h-auto min-h-[600px] w-full items-center justify-end">
      <!-- Hero Image tablet-->
      <HeroImage 
        containerClass="relative overflow-hidden h-[775px] w-[907px]"
        screen="tablet"
      />

      <!-- Content centered -->
      <HeroContent 
        bannerText={content.banner.text}
        taglineLines={content.tagline.lines}
        claimText={content.claim}
        ctaHref={content.cta.href}
        ctaText={content.cta.text}
        screen="tablet"
      />

    </div>
  </div>

  <!-- Mobile Hero -->
  <div class="relative block w-full max-w-[500px] overflow-hidden rounded-[28px] mb-5 bg-white md:hidden">
    <div class="relative flex h-fit w-full items-center justify-top">
      <!-- Hero Image Container -->
      <HeroImage 
        containerClass="relative overflow-hidden h-[625px] w-[907px]"
        screen="mobile"
      />
      <!-- Content centered -->
      <HeroContent 
        bannerText={content.banner.text}
        taglineLines={content.tagline.lines}
        claimText={content.claim}
        ctaHref={content.cta.href}
        ctaText={content.cta.text}
        screen="mobile"
      />
    </div>
  </div>

</section>

<SmoothScroll />

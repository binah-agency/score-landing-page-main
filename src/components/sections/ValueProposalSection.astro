---
import valueProposalData from '../../data/content/content.value-proposal.json';
import ValueProposalTitle from '../ui/molecules/ValueProposalTitle.astro';
import BenefitItem from '../ui/molecules/BenefitItem.astro';
import TestimonialCard from '../ui/molecules/TestimonialCard.astro';
import ScoreCard from '../ui/molecules/ScoreCard.astro';
import CTAButton from '../ui/atoms/CTAButton.astro';

const { section } = valueProposalData;
---

<section class="w-full bg-[#eff1f9] px-[197px] py-[39px]" id={section.id}>
  <div class="mx-auto flex max-w-[1920px] items-center justify-center gap-[54px]">
    <div class="flex w-[815px] shrink-0 flex-col items-start gap-[81px]">
      <ValueProposalTitle line1={section.title.line1} line2={section.title.line2} />

      <div class="flex w-full flex-col gap-6">
        <p class="font-montserrat text-[24px] font-semibold text-[var(--color-azulhorizonte)]">
          {section.subtitle}
        </p>
        <div class="grid w-full grid-cols-2 gap-4">
          {section.benefits.map((benefit, index) => (
            <BenefitItem benefit={benefit} index={index} />
          ))}
        </div>
      </div>

      <TestimonialCard testimonial={section.testimonial} />

      <CTAButton 
        href={section.cta.href} 
        text={section.cta.text}
        className="flex h-[87px] w-[763px] items-center justify-center gap-[10px] rounded-[16px] bg-[#4585c6] p-3 transition-all hover:bg-[#3a74ae]"
      />
    </div>

    <ScoreCard 
      title={section.scoreCard.title}
      badge={section.scoreCard.badge}
      score={{ score: section.scoreCard.score, scoreLabel: section.scoreCard.scoreLabel }}
      notifications={section.scoreCard.notifications}
    />
  </div>
</section>
---
// ValueProposalSection - Sección "Más que un número, es un Sello de Válidez"

// Content Data
import valueProposalData from '../../data/content.value-proposal.json';

const { section } = valueProposalData;
---

<section class="w-full bg-[#eff1f9] px-[197px] py-[39px]" id={section.id}>
  <!-- Container principal flex -->
  <div class="mx-auto flex max-w-[1920px] items-center justify-center gap-[54px]">
    
    <!-- Columna izquierda - Container -->
    <div class="flex w-[815px] shrink-0 flex-col items-start gap-[81px]">
      
      <!-- Título h2 headings -->
      <div class="flex w-full flex-col items-start pb-2">
        <p class="w-full font-montserrat text-[48px] font-bold capitalize leading-[64px] tracking-[-0.03em] text-[var(--color-black)]">
          {section.title.line1}
        </p>
        <p class="w-full font-montserrat text-[48px] font-bold capitalize leading-[64px] tracking-[-0.03em] text-[var(--color-azulhorizonte)]">
          {section.title.line2}
        </p>
      </div>

      <!-- Benefits Section -->
      <div class="flex w-full flex-col gap-6">
        <p class="font-montserrat text-[24px] font-semibold text-[var(--color-azulhorizonte)]">
          {section.subtitle}
        </p>
        <div class="grid w-full grid-cols-2 gap-4">
          {section.benefits.map((benefit, index) => (
            <div class="flex items-start gap-3">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-azulhorizonte)]">
                <span class="text-white text-sm font-bold">{index + 1}</span>
              </div>
              <div>
                <p class="font-montserrat text-[18px] font-bold text-[var(--color-black)]">
                  {benefit.title}
                </p>
                <p class="font-montserrat text-[16px] text-[var(--color-gray600)] mt-1">
                  {benefit.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Testimonial Card -->
      <div class="rounded-[32px] bg-[var(--color-azulhorizonte)] pl-6">
        <div class="flex h-[418px] flex-col items-start rounded-[32px] bg-white">
          <div class="flex flex-col items-start gap-[25px] p-8">
            
            <!-- Rating Stars -->
            <div class="flex items-center gap-[7px]">
              {Array.from({ length: section.testimonial.rating }).map(() => (
                <div class="flex h-6 w-6 items-center justify-center">
                  <svg width="20" height="19" viewBox="0 0 20 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 0L12.2451 6.90983H19.5106L13.6327 11.1803L15.8779 18.0902L10 13.8197L4.12215 18.0902L6.36729 11.1803L0.489435 6.90983H7.75486L10 0Z" fill="#86B545"/>
                  </svg>
                </div>
              ))}
            </div>

            <!-- Testimonial Content -->
            <div class="flex w-full flex-col gap-4">
              <div class="flex flex-col items-start">
                <p class="font-montserrat text-[36px] font-bold leading-[64px] tracking-[-0.03em] text-[var(--color-black)]">
                  TESTIMONIO
                </p>
                <div class="h-1 w-[287px] bg-[var(--color-azulhorizonte)]"></div>
              </div>
              
              <!-- Quote -->
              <div class="h-[141px] w-full">
                <p class="flex h-full flex-col justify-center font-montserrat text-[20px] font-medium leading-7 text-[var(--color-black)]">
                  {section.testimonial.quote}
                </p>
              </div>
            </div>

            <!-- Author -->
            <div class="flex w-[129px] flex-col items-start">
              <p class="font-montserrat text-[16px] font-bold leading-[21px] tracking-[-0.03em] text-[var(--color-black)]">
                {section.testimonial.author}
              </p>
              <p class="font-montserrat text-[14px] font-semibold italic leading-[19px] tracking-[-0.03em] text-[var(--color-azulhorizonte)]">
                {section.testimonial.role}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Button -->
      <a 
        href="#" 
        class="flex h-[87px] w-[763px] items-center justify-center gap-[10px] rounded-[16px] bg-[#4585c6] p-3 transition-all hover:bg-[#3a74ae]"
      >
        <span class="font-montserrat text-[36px] font-semibold text-white">
          {section.cta.text}
        </span>
        <svg width="61" height="60" viewBox="0 0 61 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
          <path d="M12.75 30H48.25M48.25 30L30.5 12.25M48.25 30L30.5 47.75" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Columna derecha - Card Score -->
    <div class="flex h-[610px] w-[657px] shrink-0 flex-col items-center gap-6 rounded-[36px] bg-white shadow-[0_15px_59px_rgba(0,0,0,0.15)]">
      
      <!-- Top - Header -->
      <div class="flex w-full items-center justify-between p-10">
        <p class="font-montserrat text-[36px] font-bold leading-[64px] text-[var(--color-black)]">
          Tu perfil financiero
        </p>
        <div class="flex h-[55px] w-[202px] items-center justify-center rounded-lg bg-[var(--color-azulhorizonte)] p-3">
          <span class="font-montserrat text-[24px] font-bold text-white">HÍBRIDO</span>
        </div>
      </div>

      <!-- Score Circle -->
      <div class="relative h-[296px] w-[296px]">
        <!-- Círculo de fondo gris -->
        <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 296 296">
          <circle cx="148" cy="148" r="137" stroke="#e5e7eb" stroke-width="11" fill="none" />
        </svg>
        <!-- Círculo de progreso verde -->
        <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 296 296">
          <circle 
            cx="148" 
            cy="148" 
            r="137" 
            stroke="#86B545" 
            stroke-width="11" 
            fill="none"
            stroke-dasharray="861"
            stroke-dashoffset="172"
            stroke-linecap="round"
          />
        </svg>
        <!-- Contenido central -->
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <p class="font-montserrat text-[72px] font-bold leading-[64px] text-[var(--color-azulhorizonte)]">
            742
          </p>
          <p class="mt-2 font-montserrat text-[16px] font-semibold leading-[64px] text-[var(--color-verdevitalidad)]">
            SCORE ÓPTIMO
          </p>
        </div>
      </div>

      <!-- Notifications -->
      <div class="flex w-[629px] flex-col gap-[14px] text-[16px]">
        <div class="flex w-full items-start justify-between rounded-lg bg-white p-2 tracking-[-0.03em]">
          <p class="font-montserrat font-semibold text-[var(--color-black)]">
            Alejandro Marín
          </p>
          <p class="font-montserrat font-bold text-[#6a9a35]">
            +15Pts
          </p>
        </div>
        <div class="flex w-full items-start justify-between rounded-lg bg-white p-2">
          <p class="font-montserrat font-semibold text-[var(--color-black)]">
            Perfíl empresarial verificado
          </p>
          <p class="font-montserrat font-bold tracking-[-0.03em] text-[var(--color-azulhorizonte)]">
            Completado
          </p>
        </div>
      </div>
    </div>

  </div>
</section>

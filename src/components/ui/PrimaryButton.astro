---
interface Props {
  label: string;
  href?: string;
  onClick?: string;
  disabled?: boolean;
  loading?: boolean;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  dataTrack?: string;
}

const { 
  label, 
  href = '#', 
  onClick, 
  disabled = false, 
  loading = false, 
  size = 'md', 
  class: className = '',
  dataTrack 
} = Astro.props;

const sizeClasses = {
  sm: 'h-10 px-4 text-[16px]',
  md: 'h-14 px-6 text-[20px]', 
  lg: 'h-16 px-8 text-[22px]'
};

const Tag = href ? 'a' : 'button';
---

<Tag
  {href && {href}}
  {onClick && {onclick: onClick}}
  {disabled && {disabled}}
  {dataTrack && {['data-track']: dataTrack}}
  class:list={[
    'inline-flex items-center justify-center whitespace-nowrap rounded-lg font-semibold text-white transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-[var(--color-azulhorizonte)]/30 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-[var(--color-azulhorizonte)]',
    sizeClasses[size],
    'bg-[var(--color-azulhorizonte)] hover:bg-[var(--color-azulhorizonte-alt)] active:scale-[0.98]',
    loading && 'opacity-75 cursor-not-allowed',
    className,
  ]}
  aria-disabled={disabled || loading}
>
  {loading ? (
    <>
      <svg class="animate-spin -ml-1 mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Cargando...
    </>
  ) : (
    label
  )}
</Tag>

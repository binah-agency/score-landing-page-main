---
import FeatureIcon from "./FeatureIcon.astro";

export interface Props {
  card: {
    title: string;
    range: string;
    description: string;
    benefits: string[];
    iconColor: string;
  };
  index: number;
  isActive?: boolean;
}

const { card } = Astro.props;
---

<div
  class="relative min-w-[350px] min-h-[260px] justify-center align-middle items-center flex flex-col w-fit m-auto text-gray-300 transition-all duration-300 cursor-pointer group rounded-2xl overflow-hidden relative"
  style={`
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37),
                0 0 60px var(--color-azulhorizonte)20,
                0 0 100px var(--color-azulhorizonte)10,
                inset 0 0 30px rgba(255, 255, 255, 0.05);
  `}
>
  <div class="w-full h-full gap-4 items-center align-middle justify-items-center flex flex-row px-8 py-5">
    <div
      class="w-10 h-10 rounded-full rounded-tl-none mb-4 transition-all duration-300 group-hover:scale-110 group-hover:-translate-y-1"
      style={`
        background-color: ${card.iconColor};
        box-shadow: 0 0 20px ${card.iconColor}60,
                    0 0 40px ${card.iconColor}40,
                    inset 0 0 10px rgba(255, 255, 255, 0.3);
      `}
    >
    </div>
    <div class="relative w-auto uppercase font-bold text-xl pb-5">
      {card.title}
      <p
        class="font-montserrat text-[16px] font-medium leading-4 text-[var(--color-azulhorizonte40)]"
      >
        {card.range}
      </p>
    </div>
  </div>

  <div class="px-8 py-0 relative flex w-full flex-col items-start">
    <!-- Párrafo -->
    <div class="m-auto py-5 h-[57px] w-full">
      <p
        class="flex h-full flex-col justify-center font-montserrat text-[14px] font-medium leading-4 text-[var(--color-azulhorizonte40)] text-justify"
      >
        {card.description}
      </p>
    </div>
    <!-- BOTTOM -->
    <div class="flex h-[51px] w-full flex-col items-start">
      <p
        class="font-montserrat text-[14px] font-bold uppercase leading-4 text-[var(--color-verdevitalidad)]"
      >
        BENEFICIOS
      </p>
      <div class="mt-2">
        {
          card.benefits.map((benefit) => (
            <p class="font-montserrat text-[14px] font-medium leading-4 text-[var(--color-azulhorizonte40)]">
              {benefit}
            </p>
          ))
        }
      </div>
    </div>
  </div>

  <div class="h-2 w-full bg-gradient-to-l via-blue-500 group-hover:blur-xl blur-2xl m-auto rounded transition-all absolute bottom-0">
  </div>
  
  <div class="h-0.5 group-hover:w-full bg-gradient-to-l via-blue-950 group-hover:via-blue-500 w-[70%] m-auto rounded transition-all">
  </div>
</div>

---
export interface Props {
  title: string;
  subtitle: string;
  icon: string;
  iconSrc?: string;
  className?: string;
}

const { title, subtitle, icon, iconSrc, className = '' } = Astro.props;
---

<div class={`flex items-center justify-center gap-4 p-6 rounded-xl bg-white/5 backdrop-blur-sm border border-white/10 hover:bg-white/10 transition-all duration-300 ${className}`}>
  <div class="flex-shrink-0 text-right">
    <p class="text-[24px] font-extrabold text-[#0a6de5]">{title}</p>
    <p class="text-[24px] font-bold text-white">{subtitle}</p>
  </div>
  <div class="flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-verdevitalidad)] shadow-lg">
    {iconSrc ? (
      <img src={iconSrc} alt={icon} class="h-10 w-10" />
    ) : (
      <span class="text-white text-xl font-bold">{icon}</span>
    )}
  </div>
</div>

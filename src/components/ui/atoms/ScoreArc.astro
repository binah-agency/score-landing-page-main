---
export interface Props {
  src?: string;
  alt?: string;
  className?: string;
}

const { 
  src = "/images/score-arc.svg", 
  alt = "Score arc background", 
  className = "" 
} = Astro.props;
---

<div class={`absolute left-[-3px] top-[341px] h-[867px] w-[1794px] ${className}`}>
  <img src={src} alt={alt} class="h-full w-full" />
</div>

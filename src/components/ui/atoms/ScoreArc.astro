---
export interface Props {
  src?: string;
  alt?: string;
  className?: string;
}

const { 
  src = "/images/score-arc.svg", 
  alt = "Score arc background", 
  className = "" 
} = Astro.props;
---

<div class={`absolute left-0 top-1/3 sm:top-1/2 lg:top-1/3 h-1/2 sm:h-2/3 lg:h-1/2 w-full max-w-6xl sm:max-w-5xl lg:max-w-6xl transform -translate-x-1/2 sm:-translate-x-1/2 lg:-translate-x-1/2 ${className}`}>
  <img src={src} alt={alt} class="h-full w-full object-contain" />
</div>

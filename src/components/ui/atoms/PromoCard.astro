---
import Logo from './Logo.astro';

export interface CardData {
  id: string;
  name: string;
  level: string;
  src: string;
  alt: string;
  badge: {
    text: string;
    label: string;
  };
  title: string;
  description: string;
  theme: string;
}

export interface Props {
  card: CardData;
  index: number;
  className?: string;
}

const { card, index, className = "" } = Astro.props;

// Theme mapping for styling
const themes: Record<string, {
  frontBg: string;
  badgeBg: string;
  badgeColor: string;
  textColor: string;
  backdropBefore: string;
  backdropAfter: string;
  backCardBg: string;
  backCardInnerBg: string;
  decorativeGradient1: string;
  decorativeGradient2: string;
}> = {
  blue: {
    frontBg: 'bg-gradient-to-l from-gray-800 via-blue-700 to-gray-900',
    badgeBg: 'bg-gradient-to-bl from-[#06b6d4] via-[#2563eb] to-[#6366f1]',
    badgeColor: 'bg-blue-900',
    textColor: 'text-blue-50',
    backdropBefore: 'before:from-black before:to-purple-600',
    backdropAfter: 'after:from-cyan-400 after:to-sky-300',
    backCardBg: 'bg-gradient-to-br from-blue-400 via-blue-500 to-blue-600',
    backCardInnerBg: 'bg-gradient-to-br from-blue-300 via-blue-400 to-blue-500',
    decorativeGradient1: 'via-blue-500',
    decorativeGradient2: 'via-purple-400'
  },
  teal: {
    frontBg: 'bg-gradient-to-tr from-teal-900/30 via-teal-900/70 to-emerald-900/30 ring-4 ring-teal-900/20',
    badgeBg: 'bg-gradient-to-r from-[#2dd4bf] to-[#1f2937]',
    badgeColor: 'bg-teal-900',
    textColor: 'text-teal-50',
    backdropBefore: 'before:from-black before:to-green-600',
    backdropAfter: 'after:from-cyan-400 after:to-sky-300',
    backCardBg: 'bg-gradient-to-br from-teal-400 via-teal-500 to-teal-600',
    backCardInnerBg: 'bg-gradient-to-br from-teal-300 via-teal-400 to-teal-500',
    decorativeGradient1: 'via-teal-500',
    decorativeGradient2: 'via-emerald-400'
  },
  gray: {
    frontBg: 'bg-[conic-gradient(at_top,_var(--tw-gradient-stops))] from-[#3f3f46] via-[#71717a] to-[#d4d4d8]',
    badgeBg: 'bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-[#27272a] via-[#52525b] to-[#a1a1aa]',
    badgeColor: 'bg-gray-600',
    textColor: 'text-gray-50',
    backdropBefore: 'before:from-black before:to-purple-600',
    backdropAfter: 'after:from-cyan-400 after:to-sky-300',
    backCardBg: 'bg-gradient-to-br from-gray-400 via-gray-500 to-gray-600',
    backCardInnerBg: 'bg-gradient-to-br from-gray-300 via-gray-400 to-gray-500',
    decorativeGradient1: 'via-gray-500',
    decorativeGradient2: 'via-zinc-400'
  },
  yellow: {
    frontBg: 'bg-gradient-to-tr from-yellow-600 via-yellow-500 to-yellow-600',
    badgeBg: 'bg-gradient-to-tl from-[#c2410c] via-[#f97316] to-[#fdba74]',
    badgeColor: 'bg-yellow-800',
    textColor: 'text-yellow-50',
    backdropBefore: 'before:from-black before:to-purple-600',
    backdropAfter: 'after:from-cyan-400 after:to-sky-300',
    backCardBg: 'bg-gradient-to-br from-yellow-400 via-yellow-500 to-yellow-600',
    backCardInnerBg: 'bg-gradient-to-br from-yellow-300 via-yellow-400 to-yellow-500',
    decorativeGradient1: 'via-yellow-500',
    decorativeGradient2: 'via-orange-400'
  },
  dark: {
    frontBg: 'bg-gradient-to-r from-[#0f172a] to-[#334155]',
    badgeBg: 'bg-[conic-gradient(at_bottom_right,_var(--tw-gradient-stops))] from-[#1d4ed8] via-[#1e40af] to-[#111827]',
    badgeColor: 'bg-gray-900',
    textColor: 'text-gray-50',
    backdropBefore: 'before:from-black before:to-purple-600',
    backdropAfter: 'after:from-cyan-400 after:to-sky-300',
    backCardBg: 'bg-gradient-to-br from-slate-400 via-slate-500 to-slate-600',
    backCardInnerBg: 'bg-gradient-to-br from-slate-300 via-slate-400 to-slate-500',
    decorativeGradient1: 'via-slate-500',
    decorativeGradient2: 'via-indigo-400'
  }
};

const theme = themes[card.theme] || themes.blue;
---

<div
  class={`promo-card bg-transparent absolute cursor-pointer transition-all duration-700 ease-out ${className}`}
  data-index={index}
>
  <div class="flip-card w-full relative h-full text-white bg-transparent">
    <div class="flip-card-inner bg-transparent">
      <div class="flip-card-front">
        <div
          class={`relative py-10 gap-4 flex flex-col justify-center items-center w-full h-full ${theme.textColor} ${theme.frontBg} rounded-2xl`}
        >
          <div
            class={`absolute -top-4 max-w-[300px] p-2 ${theme.badgeBg} rounded-full items-center text-indigo-100 leading-none lg:rounded-full flex lg:inline-flex`}
          >
            <span
              class={`flex rounded-full ${theme.badgeColor} uppercase px-2 py-1 text-xs font-bold mr-3`}
              >{card.badge.text}</span
            >
            <span class="font-semibold mr-2 text-left flex-auto"
              >{card.badge.label}</span
            >
            <svg
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
              class="fill-current opacity-75 h-4 w-4"
              ><path
                d="M12.95 10.707l.707-.707L8 4.343 6.586 5.757 10.828 10l-4.242 4.243L8 15.657l4.95-4.95z"
              ></path></svg
            >
          </div>

          <div class="flex flex-col items-center">
            <p class="text-4xl font-extrabold text-white">{card.name}</p>
            <p
              class="relative text-[var(--color-azulHorizonte)] text-md inline-block after:absolute after:content-[''] after:ml-2 after:top-1/2 after:bg-white/30 after:w-12 after:h-0.5 before:absolute before:content-[''] before:-ml-14 before:top-1/2 before:bg-white/30 before:w-12 before:h-0.5"
            >
              {card.level}
            </p>
          </div>

          <div
            class="mx-auto w-full max-w-xs relative flex flex-col items-center justify-center text-center overflow-visible"
          >
            <h3 class="text-3xl font-bold">{card.title}</h3>
            <div
              class="w-full relative flex flex-col items-center justify-center"
            >
              <div
                class={`absolute inset-x-auto top-0 bg-gradient-to-r from-transparent ${theme.decorativeGradient1} to-transparent h-[2px] w-full blur-sm`}
              >
              </div>
              <div
                class={`absolute inset-x-auto top-0 bg-gradient-to-r from-transparent ${theme.decorativeGradient1} to-transparent h-px w-full`}
              >
              </div>
              <div
                class={`absolute inset-x-auto top-0 bg-gradient-to-r from-transparent ${theme.decorativeGradient2} to-transparent h-[5px] w-1/2 blur-sm`}
              >
              </div>
              <div
                class={`absolute inset-x-auto top-0 bg-gradient-to-r from-transparent ${theme.decorativeGradient2} to-transparent h-px w-1/2`}
              >
              </div>
              <div
                style=""
                class="absolute inset-0 w-full h-full bg-background [mask-image:radial-gradient(50%_200px_at_top,transparent_20%,white)]"
              >
              </div>
            </div>
            <p class="mt-6 text-md">
              {card.description}
            </p>

            <span
              class={`absolute -z-[1] backdrop-blur-sm inset-0 w-full h-full flex before:content-[''] before:h-3/4 before:w-full before:bg-gradient-to-r ${theme.backdropBefore} before:blur-[90px] after:content-[''] after:h-1/2 after:w-full after:bg-gradient-to-br ${theme.backdropAfter} after:blur-[90px]`}
            ></span>
          </div>
        </div>
      </div>
      <div class="flip-card-back">
        <div
          class={`relative drop-shadow-xl h-full overflow-hidden rounded-xl ${theme.backCardBg}`}
        >
          <div class={`absolute flex items-center justify-center z-[1] opacity-90 rounded-xl inset-1 bg-gradient-to-b from-[#f3f8ff] via-[#deecff] to-[#c6cfff]`}
          >
            <div class="flex flex-col items-center">

              <p class={`text-4xl font-extrabold bg-gradient-to-r bg-[var(--color-azulHorizonte)] bg-clip-text text-[var(--color-azulhorizonte-alt)]`}>NIVEL {card.name}</p>
              <p
                class="relative text-[var(--color-azulHorizonte)] text-md inline-block "
              >
                {card.level}
              </p>

              <!-- Crediscore Logo -->
              <Logo variant='full' />
            </div>
          </div>
          <div
            class="absolute w-56 h-48 bg-white/20 blur-[50px] -left-1/2 -top-1/2"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* From Uiverse.io by Praashoo7 */
  .flip-card {
    perspective: 1000px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    text-align: center;
    transition: transform 0.8s;
    transform-style: preserve-3d;
  }

  .flip-card:hover .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    box-shadow: 0 8px 14px 0 rgba(0, 0, 0, 0.2);
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    border-radius: 1rem;
  }

  .flip-card-front {
    box-shadow:
      rgba(0, 0, 0, 0.4) 0px 2px 2px,
      rgba(0, 0, 0, 0.3) 0px 7px 13px -3px,
      rgba(0, 0, 0, 0.2) 0px -1px 0px inset;
    background-color: #171717;
  }

  .flip-card-back {
    box-shadow:
      rgba(0, 0, 0, 0.4) 0px 2px 2px,
      rgba(0, 0, 0, 0.3) 0px 7px 13px -3px,
      rgba(0, 0, 0, 0.2) 0px -1px 0px inset;
    background-color: #171717;
    transform: rotateY(180deg);
  }
</style>

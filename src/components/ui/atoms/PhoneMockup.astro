---
export interface Props {
  image: string;
  alt: string;
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { image, alt, size = 'md', className = '' } = Astro.props;

const sizeClasses = {
  sm: 'max-w-[200px]',
  md: 'max-w-[292px]',
  lg: 'max-w-[380px]',
};
---

<div class={`flex w-full items-center justify-center ${className}`}>
  <img 
    src={image} 
    alt={alt} 
    class={`h-auto w-full ${sizeClasses[size]}`}
  />
</div>
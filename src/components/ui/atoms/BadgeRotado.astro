---
// BadgeRotado - Componente para badge rotado con círculos de colores y texto (Atomic Design)
export interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="flex h-[434px] w-[92px] items-center justify-center">
  <div class="-rotate-90">
    <div class="flex w-[434px] items-center justify-center gap-[10px] rounded-[60px] p-[10px]" style="background: radial-gradient(ellipse at center, rgba(255,255,255,1) 55.77%, rgba(239,239,239,1) 90.38%, rgba(235,235,235,1) 97.6%);">
      <!-- Círculos de colores -->
      <div class="relative h-[72px] w-[152px]">
        <span class="absolute left-0 top-0 h-[72px] w-[72px] rounded-full bg-gradient-to-r from-[#e87272] to-[#e87272]"></span>
        <span class="absolute left-10 top-0 h-[72px] w-[72px] rounded-full bg-[var(--color-azulhorizonte60)]"></span>
        <span class="absolute left-20 top-0 h-[72px] w-[72px] rounded-full bg-[var(--color-verdevitalidad-light)]"></span>
      </div>
      
      <!-- Contenedor del texto -->
      <div class="flex w-[252px] flex-col items-center justify-center py-[14px]">
        <p class="whitespace-nowrap text-[20px] font-semibold text-[var(--color-black)]">{text}</p>
      </div>
    </div>
  </div>
</div>

---
// Header Organism - Complete header with navigation and actions (Atomic Design)
import Logo from '../atoms/Logo.astro';
import Navigation from '../molecules/Navigation.astro';
import HeaderActions from '../molecules/HeaderActions.astro';
import menuIcon from '../../../assest/f500dba3-f45e-43de-8e70-c2004fb0c26f.svg?url';
import heroData from '../../../data/content/content.hero.json';

const { header } = heroData;
---

<header class="fixed top-6 left-0 right-0 z-50 mx-auto w-full max-w-[1682px] bg-white/40 backdrop-blur-xl border-b border-white/18 shadow-2xl shadow-slate-900/20 rounded-full" 
>
  <!-- Desktop Header -->
  <div class="hidden h-16 items-center rounded-full bg-transparent/10 backdrop-blur-sm px-6 py-3 lg:flex">
    <Logo size="desktop" />
    <Navigation items={header.navigation} />
    <HeaderActions actions={header.actions} />
  </div>

  <!-- Tablet Header (md screens) -->
  <div class="hidden h-16 items-center justify-between rounded-full bg-transparent/10 backdrop-blur-sm px-4 py-2 md:flex lg:hidden">
    <Logo size="tablet" />
    <button class="p-2 rounded-full hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20 transition-all duration-200" aria-label="Open menu" onclick="toggleMobileMenu()">
      <img src={menuIcon} alt="Menu" class="h-6 w-6" />
    </button>
  </div>

  <!-- Mobile Header -->
  <div class="flex h-16 items-center justify-between rounded-[60px] bg-transparent/10 backdrop-blur-sm px-4 py-2 md:hidden">
    <Logo size="mobile" />
    <button class="p-2 rounded-full hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/20 transition-all duration-200" aria-label="Open menu" onclick="toggleMobileMenu()">
      <img src={menuIcon} alt="Menu" class="h-6 w-6" />
    </button>
  </div>
</header>

<!-- Mobile Menu Drawer (Hidden by default) -->
<div id="mobile-menu" class="hidden fixed inset-0 z-40 flex items-start bg-black/50 backdrop-blur-sm transition-transform duration-300 ease-in-out">
  <div class="w-full max-w-xs bg-white/20 backdrop-blur-xl border-r border-white/10 p-6 h-full flex flex-col justify-between">
    <nav class="flex-1 space-y-4">
      <Navigation items={header.navigation} />
    </nav>
    <div class="space-x-3">
      {header.actions.map((action) => (
        <a href={action.href} 
           class={`flex-1 px-4 py-2 rounded-full text-center font-semibold ${
             action.primary ? 'bg-white/20 hover:bg-white/30' : 'hover:bg-white/10'
           } transition-colors duration-200`}>
           {action.text}
         </a>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  // Mobile menu toggle functionality
  function toggleMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      // Toggle hidden class and transform for slide animation
      const isClosed = menu.classList.contains('hidden');
      
      if (isClosed) {
        menu.classList.remove('hidden');
        // Small delay to allow display change before adding transform
        requestAnimationFrame(() => {
          menu.classList.remove('-translate-x-full');
        });
      } else {
        menu.classList.add('-translate-x-full');
        // Hide after animation completes
        setTimeout(() => {
          menu.classList.add('hidden');
        }, 300);
      }
    }
  }
</script>

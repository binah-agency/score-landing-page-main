<div class="rounded-2xl shadow-lg p-3 bg-[var(--color-azulhorizonte)] text-gray-600 max-w-xs h-[400px] flex flex-col">
  <div
    class="relative flex flex-col items-center p-5 pt-10 bg-blue-100 rounded-xl flex-1"
  >
    <span
      class="mt-[-12px] absolute top-0 right-0 flex items-center bg-[var(--color-azulhorizonte)] rounded-l-full py-2 px-3 text-xl font-semibold text-amber-100"
    >
      {card.range}
    </span>
    <p
      class="text-xl font-semibold text-blue-800 px-2 py-1 rounded-xl"
    >
      {card.title}
    </p>
    <p class="text-center mt-3 flex-grow">
      {card.description}
    </p>
    <ul class="flex flex-col space-y-2 mt-4">
      {card.benefits.map((benefit) => (
        <li class="flex items-center space-x-2">
          <span
            class="flex items-center justify-center w-5 h-5 bg-teal-500 text-white rounded-full flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="14"
              height="14"
            >
              <path fill="none" d="M0 0h24v24H0z"></path>
              <path
                d="M10 15.172l9.192-9.193 1.415 1.414L10 18l-6.364-6.364 1.414-1.414z"
                fill="currentColor"
              ></path>
            </svg>
          </span>
          <span class="text-sm">{benefit}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

---
// Section Components
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import PromoSection from '../components/sections/PromoSection.astro';
import FeaturesSection from '../components/sections/FeaturesSection.astro';
import CoreModulesSection from '../components/sections/CoreModulesSection.astro';
import ModulesSection from '../components/sections/ModulesSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import UseCasesSection from '../components/sections/UseCasesSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import AppDownloadSection from '../components/sections/AppDownloadSection.astro';
import FooterSection from '../components/sections/FooterSection.astro';
import BackToTopButton from '../components/ui/BackToTopButton.astro';

// Marketing Components
import marketingKeys from '../data/marketing/marketing-keys.json';
import SEOHead from '../components/marketing/SEOHead.astro';
import SEMSchema from '../components/marketing/SEMSchema.astro';
import AEOContent from '../components/marketing/AEOContent.astro';
import AEMTracking from '../components/marketing/AEMTracking.astro';
import GTMContainer from '../components/marketing/GTMContainer.astro';
import G4Analytics from '../components/marketing/G4Analytics.astro';

const { gtm, g4 } = marketingKeys;

// LLM Marketing Components
import LLMSEO from '../components/marketing/LLMSEO.astro';
import LLMSEM from '../components/marketing/LLMSEM.astro';

// Assets
import '../styles/global.css';
import bgImage from '../assest/common/image.png?url';
import logoIcon from '../assest/ddb6da78-cb69-4dc6-b81e-c8e7de675d82.svg?url';
---

<html lang="es">
	<head>
		<!-- SEO Head Component -->
		<SEOHead />
		
		<!-- SEM Schema Markup -->
		<SEMSchema />
		
		<!-- LLM SEO Component -->
		<LLMSEO />
		
		<!-- LLM SEM Component -->
		<LLMSEM />
		
		<!-- Google Tag Manager -->
		<GTMContainer id={gtm.id} /> 
		
		<!-- Google Analytics 4 -->
		<G4Analytics id={g4.id} />
		
	</head>
	<body class="overflow-x-hidden bg-white text-[var(--color-black,#2d2d2c)] antialiased">
		<div class="relative w-full overflow-hidden">
			<!-- Imagen de fondo que scrollea con el contenido -->
			<img src={bgImage} alt="" class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover" />
			
			<main id="top" class="relative z-10 mx-auto min-h-screen w-full overflow-x-hidden">
				<HeroSection />
				<AboutSection />
				<PromoSection />
				<FeaturesSection />
				<CoreModulesSection />
				<ModulesSection />
				<CtaSection />
				<UseCasesSection />
				<FaqSection />
				<AppDownloadSection />
				<FooterSection />
			</main>
		</div>
		<BackToTopButton />
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NKMKSDN5"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
	</body>
</html>
